
# Leave values empty unless you need to override the defaults from config/settings.json.

# Example: force a specific audio device name or id
# NEXA_AUDIO_INPUT_DEVICE=USB PnP Sound Device

# Example: point NeXa to an alternative local LLM endpoint
# NEXA_LLM_BASE_URL=http://127.0.0.1:11434

# Example: switch runtime-specific flags
# NEXA_LOG_LEVEL=INFO