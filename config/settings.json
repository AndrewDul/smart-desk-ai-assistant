{
  "project": {
    "name": "NeXa",
    "version": "0.7.0",
    "stage": "premium-product-foundation"
  },
  "user": {
    "name": "Andrzej"
  },
  "voice_input": {
    "enabled": true,
    "engine": "faster_whisper",
    "wake_engine": "openwakeword",
    "wake_model_path": "models/wake/nexa.onnx",

    "wake_threshold": 0.28,
    "wake_trigger_level": 2,
    "wake_block_ms": 80,
    "wake_vad_threshold": 0.18,
    "wake_enable_speex_noise_suppression": true,
    "wake_debug": false,
    "wake_activation_cooldown_seconds": 1.25,
    "wake_block_release_settle_seconds": 0.18,
    "wake_energy_rms_threshold": 0.0060,
    "wake_score_smoothing_window": 4,

    "device_index": null,
    "device_name_contains": "reSpeaker",

    "timeout_seconds": 8,
    "active_listen_window_seconds": 10.0,
    "initial_command_window_seconds": 5.8,
    "follow_up_window_seconds": 9.0,
    "post_response_listen_window_seconds": 7.0,
    "thinking_ack_seconds": 1.2,

    "debug": false,
    "sample_rate": 16000,
    "max_record_seconds": 7.2,
    "end_silence_seconds": 0.60,
    "pre_roll_seconds": 0.50,
    "blocksize": 512,
    "min_speech_seconds": 0.18,
    "transcription_timeout_seconds": 12.0,
    "threads": 4,
    "language": "auto",
    "vad_enabled": true,
    "vad_threshold": 0.24,
    "vad_min_speech_ms": 140,
    "vad_min_silence_ms": 320,
    "vad_speech_pad_ms": 220,

    "compute_type": "int8",
    "beam_size": 1,
    "best_of": 1,
    "model_size_or_path": "tiny",
    "whisper_cli_path": "whisper.cpp/build/bin/whisper-cli",
    "model_path": "models/ggml-base.bin",
    "vad_model_path": "models/ggml-silero-v6.2.0.bin"
  },
  "voice_output": {
    "enabled": true,
    "engine": "piper",
    "default_language": "en",
    "speed": 155,
    "pitch": 58,
    "voices": {
      "pl": "pl+f3",
      "en": "en+f3"
    },
    "piper_models": {
      "pl": {
        "model": "voices/piper/pl_PL-gosia-medium.onnx",
        "config": "voices/piper/pl_PL-gosia-medium.onnx.json"
      },
      "en": {
        "model": "voices/piper/en_GB-jenny_dioco-medium.onnx",
        "config": "voices/piper/en_GB-jenny_dioco-medium.onnx.json"
      }
    }
  },
  "display": {
    "enabled": true,
    "driver": "waveshare_2inch",
    "interface": "spi",
    "port": 1,
    "address": 60,
    "rotate": 0,
    "width": 240,
    "height": 320,
    "gpio_dc": 25,
    "gpio_rst": 27,
    "gpio_light": 18,
    "spi_port": 0,
    "spi_device": 0,
    "default_overlay_seconds": 8,
    "boot_overlay_seconds": 2.4
  },
  "timers": {
    "default_focus_minutes": 25,
    "default_break_minutes": 5
  },
  "streaming": {
    "dialogue_stream_mode": "sentence",
    "inter_chunk_pause_seconds": 0.0,
    "max_display_lines": 2,
    "max_display_chars_per_line": 20
  },
  "audio_coordination": {
    "self_hearing_hold_seconds": 0.90,
    "listen_resume_poll_seconds": 0.04
  },
  "conversation": {
    "max_turns": 8,
    "max_total_chars": 1800
  },
  "llm": {
    "enabled": false,
    "runner": "llama-cli",
    "command": "llama-cli",
    "model_path": "models/Qwen2.5-1.5B-Instruct-Q4_K_M.gguf",
    "n_predict": 96,
    "temperature": 0.7,
    "top_p": 0.9,
    "top_k": 40,
    "ctx_size": 2048,
    "threads": 4,
    "timeout_seconds": 18.0,
    "repeat_penalty": 1.1,
    "max_prompt_chars": 2400,
    "prefer_json": false,
    "server_url": "http://127.0.0.1:8080",
    "server_chat_path": "/v1/chat/completions",
    "server_health_path": "/health",
    "server_api_key": "",
    "server_model_name": "",
    "server_use_openai_compat": true,
    "server_connect_timeout_seconds": 3.0
  },
  "logging": {
    "enabled": true,
    "console_enabled": false,
    "log_file": "var/logs/system.log",
    "max_bytes": 1000000,
    "backup_count": 2
  },
  "system": {
    "allow_shutdown_commands": false,
    "shutdown_command": [
      "systemctl",
      "poweroff"
    ]
  },
  "fast_command_lane": {
    "enabled": true
  },
  "vision": {
    "enabled": false,
    "camera_index": 0,
    "frame_width": 1280,
    "frame_height": 720,
    "face_detection_enabled": false,
    "object_detection_enabled": false,
    "scene_understanding_enabled": false,
    "gesture_recognition_enabled": false,
    "behavior_interpretation_enabled": false
  },
  "mobility": {
    "enabled": false,
    "base_type": "differential",
    "safety_stop_enabled": true,
    "max_linear_speed": 0.3,
    "max_turn_speed": 0.5
  }
}