{
  "project": {
    "name": "Smart Desk AI Assistant",
    "version": "0.2.0-whisper-alpha",
    "stage": "stage-1-stationary-core"
  },
  "user": {
    "name": "Andrzej"
  },
  "voice_input": {
    "enabled": true,
    "engine": "whisper",
    "device_index": null,
    "device_name_contains": null,
    "timeout_seconds": 8,
    "debug": false,
    "sample_rate": 16000,
    "max_record_seconds": 8.0,
    "silence_threshold": 350.0,
    "end_silence_seconds": 1.0,
    "pre_roll_seconds": 0.4,
    "threads": 4,
    "language": "auto",
    "vad_enabled": true,
    "whisper_cli_path": "whisper.cpp/build/bin/whisper-cli",
    "model_path": "models/ggml-base.bin",
    "vad_model_path": "models/ggml-silero-v6.2.0.bin"
  },
  "voice_output": {
    "enabled": true,
    "engine": "espeak-ng"
  },
  "display": {
    "enabled": true,
    "driver": "ssd1306",
    "interface": "i2c",
    "port": 1,
    "address": 60,
    "rotate": 0,
    "width": 128,
    "height": 64,
    "default_overlay_seconds": 10,
    "boot_overlay_seconds": 4
  },
  "timers": {
    "default_focus_minutes": 25,
    "default_break_minutes": 5
  },
  "logging": {
    "enabled": true,
    "log_file": "logs/system.log"
  }
}