# --------------------------------------------------
# Python
# --------------------------------------------------
__pycache__/
*.py[cod]
*$py.class

# --------------------------------------------------
# Virtual environments
# --------------------------------------------------
.venv/
venv/
env/
ENV/

# --------------------------------------------------
# Test / tooling caches
# --------------------------------------------------
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
coverage.xml
htmlcov/

# --------------------------------------------------
# IDE / editor
# --------------------------------------------------
.vscode/
.idea/
*.swp
*.swo

# --------------------------------------------------
# OS files
# --------------------------------------------------
.DS_Store
Thumbs.db

# --------------------------------------------------
# Runtime state (canonical)
# --------------------------------------------------
var/data/
var/logs/
var/cache/

# --------------------------------------------------
# Legacy runtime state (should be removed from repo)
# --------------------------------------------------
data/
logs/
cache/

# --------------------------------------------------
# Local temp / audio artifacts
# --------------------------------------------------
tmp/
temp/
*.wav
*.pcm

# --------------------------------------------------
# Build / packaging
# --------------------------------------------------
build/
dist/
*.egg-info/

# --------------------------------------------------
# Environment / secrets
# --------------------------------------------------
.env
.env.*
!.env.example

# --------------------------------------------------
# Local native build artifacts
# Keep source trees, ignore compiled outputs.
# --------------------------------------------------
third_party/llama.cpp/build/
third_party/whisper.cpp/build/
llama.cpp/build/
whisper.cpp/build/

# --------------------------------------------------
# Optional local model artifacts
# Keep committed product assets manually if needed.
# Uncomment only if you decide to keep models outside git.
# --------------------------------------------------
models/**/*.gguf
models/**/*.bin
voices/piper/**/*.onnx
voices/piper/**/*.json