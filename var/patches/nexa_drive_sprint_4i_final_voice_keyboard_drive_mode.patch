+def write(rel_path: str, content: str) -> None:
+    path = PROJECT_ROOT / rel_path
+    path.parent.mkdir(parents=True, exist_ok=True)
+    path.write_text(textwrap.dedent(content).lstrip("\n").rstrip() + "\n", encoding="utf-8")
+    print(f"[REPAIR] wrote {rel_path}")
+
+
+def patch_file(rel_path: str, checks: list[tuple[str, str, str]]) -> None:
+    path = PROJECT_ROOT / rel_path
+    text = path.read_text(encoding="utf-8")
+    original = text
+    for present, needle, replacement in checks:
+        if present in text:
+            continue
+        if needle not in text:
+            raise RuntimeError(f"Cannot patch {rel_path}; missing needle: {needle!r}")
+        text = text.replace(needle, replacement, 1)
+    if text != original:
+        path.write_text(text, encoding="utf-8")
+        print(f"[REPAIR] patched {rel_path}")
+    else:
+        print(f"[REPAIR] checked {rel_path}")
+
