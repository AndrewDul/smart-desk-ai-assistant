+++ b/scripts/mobile_base_drive_mode.py
@@ -0,0 +1,340 @@
+#!/usr/bin/env python3
+from __future__ import annotations
+
+import argparse
+import json
+import os
+import signal
+import sys
+import threading
+import time
+from http.server import BaseHTTPRequestHandler, ThreadingHTTPServer
+from pathlib import Path
+from typing import Any
+
+PROJECT_ROOT = Path(__file__).resolve().parents[1]
+if str(PROJECT_ROOT) not in sys.path:
+    sys.path.insert(0, str(PROJECT_ROOT))
+
+from modules.devices.mobile_base import (  # noqa: E402
+    DEFAULT_BAUDRATE,
+    DEFAULT_TIMEOUT_SEC,
+    DEFAULT_MOVEMENT_CONFIRM_ENV,
+    DEFAULT_MOVEMENT_CONFIRM_VALUE,
+    DryRunSerialTransport,
+    MobileBaseController,
+    MobileBaseSafetyPolicy,
+    PySerialLineTransport,
+    choose_serial_port,
+)
+from modules.runtime.drive_mode import DriveModeService  # noqa: E402
+
+
+CONFIRM_TEST_ENV_VAR = "CONFIRM_NEXA_MOBILE_BASE_TEST"
+CONFIRM_TEST_ENV_VALUE = "RUN"
+DEFAULT_HTTP_HOST = "127.0.0.1"
+DEFAULT_HTTP_PORT = 8768
+
+
+HTML_PAGE = """<!doctype html>
+<html lang="en">
+<head>
+  <meta charset="utf-8">
+  <meta name="viewport" content="width=device-width, initial-scale=1">
+  <title>NeXa Drive Mode</title>
+  <style>
+    :root { color-scheme: dark; font-family: system-ui, -apple-system, BlinkMacSystemFont, sans-serif; }
+    body { margin: 0; min-height: 100vh; background: #0b0d12; color: #f4f7fb; display: grid; place-items: center; }
+    main { width: min(720px, calc(100vw - 32px)); padding: 28px; border: 1px solid #252b36; border-radius: 24px; background: #111722; box-shadow: 0 24px 80px rgba(0,0,0,.45); }
+    h1 { margin: 0 0 10px; font-size: 28px; }
+    p { color: #aeb8c8; line-height: 1.55; }
+    .grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 12px; margin: 24px 0; }
+    .key { border: 1px solid #334052; border-radius: 18px; padding: 22px 10px; text-align: center; background: #182131; font-size: 24px; font-weight: 750; user-select: none; }
+    .key.active { outline: 3px solid #8ab4ff; }
+    .empty { visibility: hidden; }
+    button { width: 100%; border: 0; border-radius: 18px; padding: 18px; font-size: 18px; font-weight: 800; color: white; background: #9b1c31; cursor: pointer; }
+    code { color: #d8e4ff; }
+    pre { min-height: 90px; max-height: 180px; overflow: auto; padding: 16px; border-radius: 16px; background: #080b10; color: #c8d6ea; }
+  </style>
+</head>
+<body>
+  <main>
+    <h1>NeXa Drive Mode</h1>
+    <p>Use <code>W/A/S/D</code> or arrow keys. Release the key to STOP. <code>Space</code> sends emergency STOP. <code>Esc</code> stops and asks the server to exit drive mode.</p>
+    <div class="grid">
+      <div class="empty"></div><div class="key" data-key="w">W</div><div class="empty"></div>
+      <div class="key" data-key="a">A</div><div class="key" data-key="s">S</div><div class="key" data-key="d">D</div>
+    </div>
+    <button id="stop">EMERGENCY STOP</button>
+    <p id="status">Status: ready</p>
+    <pre id="log"></pre>
+  </main>
+<script>
+const pressed = new Set();
+const activeByKey = {"w":"w", "a":"a", "s":"s", "d":"d", "ArrowUp":"w", "ArrowLeft":"a", "ArrowDown":"s", "ArrowRight":"d"};
+const log = document.getElementById("log");
+const statusBox = document.getElementById("status");
+function append(message) {
+  const time = new Date().toLocaleTimeString();
+  log.textContent = `[${time}] ${message}\n` + log.textContent;
+}
+async function send(event, key) {
+  const response = await fetch('/api/key', {
+    method: 'POST',
+    headers: {'Content-Type': 'application/json'},
+    body: JSON.stringify({event, key})
+  });
+  const data = await response.json();
+  statusBox.textContent = `Status: ${data.ok ? 'ok' : 'error'} ${data.action || ''}`;
+  append(JSON.stringify(data));
+  return data;
+}
+function mark(key, active) {
+  const mapped = activeByKey[key] || key.toLowerCase();
+  const node = document.querySelector(`[data-key="${mapped}"]`);
+  if (node) node.classList.toggle('active', active);
+}
+document.addEventListener('keydown', async (event) => {
+  if (["w", "a", "s", "d", " ", "Escape", "ArrowUp", "ArrowLeft", "ArrowDown", "ArrowRight"].includes(event.key)) {
+    event.preventDefault();
+  }
+  if (event.key === ' ') {
+    await send('down', 'space');
+    return;
+  }
+  if (event.key === 'Escape') {
+    await send('down', 'escape');
+    return;
+  }
+  const key = event.key.length === 1 ? event.key.toLowerCase() : event.key;
+  if (!pressed.has(key)) pressed.add(key);
+  mark(key, true);
+  if (["w", "a", "s", "d", "ArrowUp", "ArrowLeft", "ArrowDown", "ArrowRight"].includes(key)) {
+    await send('down', key);
+  }
+});
+document.addEventListener('keyup', async (event) => {
+  const key = event.key.length === 1 ? event.key.toLowerCase() : event.key;
+  pressed.delete(key);
+  mark(key, false);
+  if (["w", "a", "s", "d", "ArrowUp", "ArrowLeft", "ArrowDown", "ArrowRight"].includes(key)) {
+    await send('up', key);
+  }
+});
+setInterval(() => {
+  for (const key of pressed) {
+    if (["w", "a", "s", "d", "ArrowUp", "ArrowLeft", "ArrowDown", "ArrowRight"].includes(key)) {
+      send('down', key).catch(() => {});
+    }
+  }
+}, 90);
+document.getElementById('stop').addEventListener('click', () => send('down', 'space'));
+window.addEventListener('blur', () => send('down', 'space').catch(() => {}));
+append('Drive panel loaded. Keep wheels raised for hardware tests.');
+</script>
+</body>
+</html>
+"""
+
+
+class DriveModeHTTPServer(ThreadingHTTPServer):
+    service: DriveModeService
+    should_exit: threading.Event
+
+
+def _json_response(handler: BaseHTTPRequestHandler, payload: dict[str, Any], *, status: int = 200) -> None:
+    encoded = json.dumps(payload, separators=(",", ":")).encode("utf-8")
+    handler.send_response(status)
+    handler.send_header("Content-Type", "application/json")
+    handler.send_header("Content-Length", str(len(encoded)))
+    handler.end_headers()
+    handler.wfile.write(encoded)
+
+
+class DriveModeRequestHandler(BaseHTTPRequestHandler):
+    server: DriveModeHTTPServer
+
+    def log_message(self, format: str, *args: Any) -> None:  # noqa: A002
+        return
+
+    def do_GET(self) -> None:  # noqa: N802
+        if self.path == "/" or self.path.startswith("/?"):
+            encoded = HTML_PAGE.encode("utf-8")
+            self.send_response(200)
+            self.send_header("Content-Type", "text/html; charset=utf-8")
+            self.send_header("Content-Length", str(len(encoded)))
+            self.end_headers()
+            self.wfile.write(encoded)
+            return
+        if self.path == "/api/status":
+            _json_response(self, {"ok": True, "exit_requested": self.server.service.exit_requested})
+            return
+        self.send_error(404)
+
+    def do_POST(self) -> None:  # noqa: N802
+        if self.path == "/api/stop":
+            result = self.server.service.stop_all(reason="drive_mode_http_stop")
+            _json_response(self, result.as_dict())
+            return
+        if self.path != "/api/key":
+            self.send_error(404)
+            return
+        try:
+            length = int(self.headers.get("Content-Length", "0"))
+            payload = json.loads(self.rfile.read(length).decode("utf-8") or "{}")
+            result = self.server.service.handle_keyboard_event(
+                event=str(payload.get("event", "")),
+                key=str(payload.get("key", "")),
+            )
+        except Exception as error:
+            _json_response(self, {"ok": False, "error": str(error)}, status=400)
+            return
+        if result.exit_requested:
+            self.server.should_exit.set()
+        status = 200 if result.ok else 400
+        _json_response(self, result.as_dict(), status=status)
+
+
+def build_parser() -> argparse.ArgumentParser:
+    parser = argparse.ArgumentParser(description="Run a safe local web drive panel for NeXa mobile base.")
+    parser.add_argument("--dry-run", action="store_true", help="Use in-memory transport instead of hardware serial.")
+    parser.add_argument("--self-test", action="store_true", help="Run a dry-run command path check and exit.")
+    parser.add_argument("--port", type=str, default=None, help="Serial device path.")
+    parser.add_argument("--baudrate", type=int, default=DEFAULT_BAUDRATE)
+    parser.add_argument("--timeout-sec", type=float, default=DEFAULT_TIMEOUT_SEC)
+    parser.add_argument("--host", type=str, default=DEFAULT_HTTP_HOST)
+    parser.add_argument("--http-port", type=int, default=DEFAULT_HTTP_PORT)
+    parser.add_argument("--stop-repeat", type=int, default=3)
+    parser.add_argument("--linear-speed-mps", type=float, default=0.04)
+    parser.add_argument("--angular-speed-rad-s", type=float, default=0.18)
+    parser.add_argument("--deadman-timeout-ms", type=int, default=250)
+    parser.add_argument("--enable-movement", action="store_true", help="Allow non-zero movement after env gates pass.")
+    return parser
+
+
+def _test_gate_is_open() -> bool:
+    return os.environ.get(CONFIRM_TEST_ENV_VAR) == CONFIRM_TEST_ENV_VALUE
+
+
+def _build_controller(args: argparse.Namespace) -> tuple[MobileBaseController, str, bool]:
+    if args.dry_run or args.self_test:
+        selected_port = args.port or "dry-run:auto"
+        transport = DryRunSerialTransport()
+        is_dry_run = True
+    else:
+        if not _test_gate_is_open():
+            raise RuntimeError(
+                f"Hardware gate is closed. Set {CONFIRM_TEST_ENV_VAR}={CONFIRM_TEST_ENV_VALUE} "
+                "before opening real serial."
+            )
+        selected_port = choose_serial_port(explicit_port=args.port)
+        transport = PySerialLineTransport(
+            port=selected_port,
+            baudrate=int(args.baudrate),
+            timeout_sec=float(args.timeout_sec),
+        )
+        is_dry_run = False
+
+    safety_policy = MobileBaseSafetyPolicy(
+        movement_enabled=bool(args.enable_movement or args.self_test),
+        require_movement_confirm_env=not bool(args.self_test),
+        default_linear_speed_mps=float(args.linear_speed_mps),
+        default_angular_speed_rad_s=float(args.angular_speed_rad_s),
+        max_linear_speed_mps=max(0.01, abs(float(args.linear_speed_mps))),
+        max_angular_speed_rad_s=max(0.01, abs(float(args.angular_speed_rad_s))),
+        deadman_timeout_ms=int(args.deadman_timeout_ms),
+    )
+    controller = MobileBaseController(
+        transport=transport,
+        safety_policy=safety_policy,
+        stop_repeat=int(args.stop_repeat),
+    )
+    return controller, selected_port, is_dry_run
+
+
+def _run_self_test(args: argparse.Namespace) -> int:
+    controller, selected_port, _is_dry_run = _build_controller(args)
+    service = DriveModeService(controller=controller)
+    controller.open()
+    try:
+        print(f"[SELF-TEST] Selected port: {selected_port}")
+        print(service.handle_keyboard_event(event="down", key="w").as_dict())
+        print(service.handle_keyboard_event(event="up", key="w").as_dict())
+        print(service.handle_keyboard_event(event="down", key="space").as_dict())
+        print("[OK] Drive mode self-test completed.")
+        return 0
+    finally:
+        controller.close()
+
+
+def main(argv: list[str] | None = None) -> int:
+    args = build_parser().parse_args(argv)
+    if args.self_test:
+        args.dry_run = True
+        return _run_self_test(args)
+
+    try:
+        controller, selected_port, is_dry_run = _build_controller(args)
+    except Exception as error:
+        print(f"[ERROR] {error}")
+        return 2
+
+    print("[INFO] NeXa mobile base drive mode starting.")
+    print(f"[INFO] Selected port: {selected_port}")
+    print(f"[INFO] Mode: {'dry-run' if is_dry_run else 'hardware'}")
+    print(f"[INFO] Movement enabled flag: {bool(args.enable_movement)}")
+    print(f"[INFO] Movement env gate: {DEFAULT_MOVEMENT_CONFIRM_ENV}={DEFAULT_MOVEMENT_CONFIRM_VALUE}")
+
+    if not is_dry_run and not args.enable_movement:
+        print("[INFO] Hardware serial may open, but non-zero movement is blocked without --enable-movement.")
+    if not is_dry_run and args.enable_movement:
+        print("[WARN] Hardware movement is enabled. Keep wheels raised and keep the web panel focused.")
+
+    service = DriveModeService(controller=controller)
+    stop_event = threading.Event()
+
+    def _handle_signal(_signum: int, _frame: object) -> None:
+        stop_event.set()
+
+    signal.signal(signal.SIGINT, _handle_signal)
+    signal.signal(signal.SIGTERM, _handle_signal)
+
+    try:
+        controller.open()
+        service.stop_all(reason="drive_mode_start_stop")
+        server = DriveModeHTTPServer((str(args.host), int(args.http_port)), DriveModeRequestHandler)
+        server.service = service
+        server.should_exit = threading.Event()
+        thread = threading.Thread(target=server.serve_forever, daemon=True)
+        thread.start()
+        print(f"[OK] Open this on the Raspberry Pi: http://{args.host}:{int(args.http_port)}/")
+        print("[INFO] Press Ctrl+C in this terminal for final STOP and exit.")
+        while not stop_event.is_set() and not server.should_exit.is_set() and not service.exit_requested:
+            result = service.check_deadman()
+            if result.deadman_stop:
+                print("[WATCHDOG] Dead-man STOP sent.")
+            time.sleep(0.05)
+        server.shutdown()
+        thread.join(timeout=2.0)
+        service.stop_all(reason="drive_mode_shutdown")
+        print("[OK] Drive mode stopped safely.")
+        return 0
+    except PermissionError:
+        print("[ERROR] Permission denied when opening the serial port.")
+        return 3
+    except Exception as error:
+        print(f"[ERROR] {error}")
+        try:
+            service.stop_all(reason="drive_mode_exception")
+        except Exception:
+            pass
+        return 4
+    finally:
+        try:
+            controller.close()
+        except Exception:
+            pass
+
+
+if __name__ == "__main__":
+    raise SystemExit(main(sys.argv[1:]))
