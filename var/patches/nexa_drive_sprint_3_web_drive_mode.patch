+from __future__ import annotations
+
+from dataclasses import dataclass
+from typing import Any, Protocol
+
+from .keyboard_mapping import DriveModeAction, MOTION_ACTIONS, map_keyboard_event
+
+
+class DriveController(Protocol):
+    """Controller subset required by manual drive mode."""
+
+    def drive_forward(self, *, speed_mps: float | None = None) -> str:
+        ...
+
+    def drive_backward(self, *, speed_mps: float | None = None) -> str:
+        ...
+
+    def rotate_left(self, *, speed_rad_s: float | None = None) -> str:
+        ...
+
+    def rotate_right(self, *, speed_rad_s: float | None = None) -> str:
+        ...
+
+    def stop(self, *, reason: str = "stop") -> list[str]:
+        ...
+
+    def check_deadman(self, *, now_monotonic: float | None = None) -> bool:
+        ...
+
+
+@dataclass(frozen=True, slots=True)
+class DriveModeEventResult:
+    """Result returned after handling one drive-mode input event."""
+
+    ok: bool
+    action: DriveModeAction
+    event: str
+    command: str | None = None
+    stopped: bool = False
+    exit_requested: bool = False
+    deadman_stop: bool = False
+    error: str | None = None
+
+    def as_dict(self) -> dict[str, Any]:
+        return {
+            "ok": self.ok,
+            "action": self.action.value,
+            "event": self.event,
+            "command": self.command,
+            "stopped": self.stopped,
+            "exit_requested": self.exit_requested,
+            "deadman_stop": self.deadman_stop,
+            "error": self.error,
+        }
+
+
+class DriveModeService:
+    """
+    Manual drive-mode coordinator.
+
+    Browser keydown events refresh the active movement command. Browser keyup,
+    Space, Escape, controller errors and the dead-man watchdog all route through
+    STOP before the script exits or accepts the next command.
+    """
+
+    def __init__(
+        self,
+        *,
+        controller: DriveController,
+        linear_speed_mps: float | None = None,
+        angular_speed_rad_s: float | None = None,
+    ) -> None:
+        self.controller = controller
+        self.linear_speed_mps = linear_speed_mps
+        self.angular_speed_rad_s = angular_speed_rad_s
+        self.active_action: DriveModeAction | None = None
+        self.exit_requested = False
+
+    def handle_keyboard_event(self, *, event: str, key: str) -> DriveModeEventResult:
+        """Handle one keydown/keyup event from the local drive panel."""
+
+        normalized_event = str(event or "").strip().lower()
+        action = map_keyboard_event(key)
+
+        if action is DriveModeAction.UNKNOWN:
+            return DriveModeEventResult(ok=False, action=action, event=normalized_event, error="unknown_key")
+        if normalized_event not in {"down", "up"}:
+            return DriveModeEventResult(ok=False, action=action, event=normalized_event, error="unknown_event")
+
+        if normalized_event == "up":
+            return self._handle_key_up(action=action, event=normalized_event)
+        return self._handle_key_down(action=action, event=normalized_event)
+
+    def _handle_key_down(self, *, action: DriveModeAction, event: str) -> DriveModeEventResult:
+        if action is DriveModeAction.EMERGENCY_STOP:
+            self.active_action = None
+            self.controller.stop(reason="drive_mode_emergency_stop")
+            return DriveModeEventResult(ok=True, action=action, event=event, stopped=True)
+
+        if action is DriveModeAction.EXIT:
+            self.active_action = None
+            self.exit_requested = True
+            self.controller.stop(reason="drive_mode_exit")
+            return DriveModeEventResult(
+                ok=True,
+                action=action,
+                event=event,
+                stopped=True,
+                exit_requested=True,
+            )
+
+        if action in MOTION_ACTIONS:
+            try:
+                command = self._send_motion(action)
+            except Exception as error:
+                self.active_action = None
+                self._best_effort_stop(reason="drive_mode_motion_error")
+                return DriveModeEventResult(
+                    ok=False,
+                    action=action,
+                    event=event,
+                    stopped=True,
+                    error=str(error),
+                )
+            self.active_action = action
+            return DriveModeEventResult(ok=True, action=action, event=event, command=command)
+
+        return DriveModeEventResult(ok=False, action=action, event=event, error="unsupported_action")
+
+    def _handle_key_up(self, *, action: DriveModeAction, event: str) -> DriveModeEventResult:
+        if action in MOTION_ACTIONS and self.active_action is action:
+            self.active_action = None
+            self.controller.stop(reason="drive_mode_key_release")
+            return DriveModeEventResult(ok=True, action=action, event=event, stopped=True)
+
+        if action is DriveModeAction.EMERGENCY_STOP:
+            return DriveModeEventResult(ok=True, action=action, event=event)
+
+        if action is DriveModeAction.EXIT:
+            return DriveModeEventResult(ok=True, action=action, event=event, exit_requested=self.exit_requested)
+
+        return DriveModeEventResult(ok=True, action=action, event=event)
+
+    def _send_motion(self, action: DriveModeAction) -> str:
+        if action is DriveModeAction.FORWARD:
+            return self.controller.drive_forward(speed_mps=self.linear_speed_mps)
+        if action is DriveModeAction.BACKWARD:
+            return self.controller.drive_backward(speed_mps=self.linear_speed_mps)
+        if action is DriveModeAction.ROTATE_LEFT:
+            return self.controller.rotate_left(speed_rad_s=self.angular_speed_rad_s)
+        if action is DriveModeAction.ROTATE_RIGHT:
+            return self.controller.rotate_right(speed_rad_s=self.angular_speed_rad_s)
+        raise ValueError(f"Unsupported motion action: {action.value}")
+
+    def check_deadman(self, *, now_monotonic: float | None = None) -> DriveModeEventResult:
+        """Run one watchdog tick and report whether it sent STOP."""
+
+        sent_stop = self.controller.check_deadman(now_monotonic=now_monotonic)
+        if sent_stop:
+            previous_action = self.active_action or DriveModeAction.EMERGENCY_STOP
+            self.active_action = None
+            return DriveModeEventResult(
+                ok=True,
+                action=previous_action,
+                event="deadman",
+                stopped=True,
+                deadman_stop=True,
+            )
+        return DriveModeEventResult(ok=True, action=DriveModeAction.UNKNOWN, event="deadman")
+
+    def stop_all(self, *, reason: str = "drive_mode_stop_all") -> DriveModeEventResult:
+        self.active_action = None
+        self.controller.stop(reason=reason)
+        return DriveModeEventResult(
+            ok=True,
+            action=DriveModeAction.EMERGENCY_STOP,
+            event="stop_all",
+            stopped=True,
+        )
+
+    def _best_effort_stop(self, *, reason: str) -> None:
+        try:
+            self.controller.stop(reason=reason)
+        except Exception:
+            pass
+
+
+__all__ = ["DriveController", "DriveModeEventResult", "DriveModeService"]
diff --git a/modules/runtime/drive_mode/keyboard_mapping.py b/modules/runtime/drive_mode/keyboard_mapping.py
