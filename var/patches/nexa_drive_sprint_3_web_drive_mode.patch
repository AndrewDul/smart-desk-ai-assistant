index 0000000..28b3f73
--- /dev/null
+++ b/modules/runtime/drive_mode/keyboard_mapping.py
@@ -0,0 +1,63 @@
+from __future__ import annotations
+
+from enum import Enum
+
+
+class DriveModeAction(str, Enum):
+    """High-level manual drive actions produced by keyboard input."""
+
+    FORWARD = "forward"
+    BACKWARD = "backward"
+    ROTATE_LEFT = "rotate_left"
+    ROTATE_RIGHT = "rotate_right"
+    EMERGENCY_STOP = "emergency_stop"
+    EXIT = "exit"
+    UNKNOWN = "unknown"
+
+
+_KEY_ALIASES: dict[str, DriveModeAction] = {
+    "w": DriveModeAction.FORWARD,
+    "arrowup": DriveModeAction.FORWARD,
+    "s": DriveModeAction.BACKWARD,
+    "arrowdown": DriveModeAction.BACKWARD,
+    "a": DriveModeAction.ROTATE_LEFT,
+    "arrowleft": DriveModeAction.ROTATE_LEFT,
+    "d": DriveModeAction.ROTATE_RIGHT,
+    "arrowright": DriveModeAction.ROTATE_RIGHT,
+    " ": DriveModeAction.EMERGENCY_STOP,
+    "space": DriveModeAction.EMERGENCY_STOP,
+    "spacebar": DriveModeAction.EMERGENCY_STOP,
+    "escape": DriveModeAction.EXIT,
+    "esc": DriveModeAction.EXIT,
+}
+
+
+MOTION_ACTIONS = frozenset(
+    {
+        DriveModeAction.FORWARD,
+        DriveModeAction.BACKWARD,
+        DriveModeAction.ROTATE_LEFT,
+        DriveModeAction.ROTATE_RIGHT,
+    }
+)
+
+
+def normalize_key(raw_key: str) -> str:
+    """Normalize browser and terminal key names to one stable representation."""
+
+    raw = str(raw_key or "")
+    if raw == " ":
+        return " "
+    key = raw.strip()
+    if len(key) == 1:
+        return key.lower()
+    return key.replace(" ", "").lower()
+
+
+def map_keyboard_event(raw_key: str) -> DriveModeAction:
+    """Map a raw keyboard key to a drive action."""
+
+    return _KEY_ALIASES.get(normalize_key(raw_key), DriveModeAction.UNKNOWN)
+
+
+__all__ = ["DriveModeAction", "MOTION_ACTIONS", "map_keyboard_event", "normalize_key"]
