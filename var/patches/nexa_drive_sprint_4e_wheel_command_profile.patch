+    def _build_profile_velocity_command(
+        self,
+        *,
+        linear_x_mps: float,
+        angular_z_rad_s: float,
+    ) -> dict[str, int | float]:
+        if self.command_profile == "ros":
+            return build_ros_velocity_command(
+                linear_x_mps=linear_x_mps,
+                angular_z_rad_s=angular_z_rad_s,
+            )
+        if self.command_profile == "wheel":
+            left_mps, right_mps = self._wheel_speeds_from_velocity(
+                linear_x_mps=linear_x_mps,
+                angular_z_rad_s=angular_z_rad_s,
+            )
+            return build_wheel_velocity_command(left_mps=left_mps, right_mps=right_mps)
+        raise MobileBaseCommandError(f"Unsupported command profile: {self.command_profile}")
+
+    def _wheel_speeds_from_velocity(self, *, linear_x_mps: float, angular_z_rad_s: float) -> tuple[float, float]:
+        if is_zero_velocity(linear_x_mps=linear_x_mps, angular_z_rad_s=angular_z_rad_s):
+            return 0.0, 0.0
+        turn_component = 0.0
+        if abs(float(angular_z_rad_s)) >= 1e-9:
+            turn_component = self._wheel_turn_component(angular_z_rad_s=angular_z_rad_s)
+        left = self.safety_policy.clamp_linear_speed(float(linear_x_mps) - turn_component)
+        right = self.safety_policy.clamp_linear_speed(float(linear_x_mps) + turn_component)
+        return left, right
+
+    def _wheel_turn_component(self, *, angular_z_rad_s: float) -> float:
+        sign = 1.0 if float(angular_z_rad_s) > 0.0 else -1.0
+        configured = self.wheel_turn_speed_mps
+        if configured <= 0.0:
+            configured = abs(float(angular_z_rad_s)) * 0.4
+        configured = max(0.04, configured)
+        configured = min(abs(float(self.safety_policy.max_linear_speed_mps)), configured)
+        return sign * configured
+
