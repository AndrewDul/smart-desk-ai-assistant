+#!/usr/bin/env python3
+"""Start NeXa with hardware-ready manual drive mode environment.
+
+This launcher keeps the hardware safety gate explicit: real movement is only
+enabled when the operator passes --enable-movement. It also forces the drive
+panel to restart so stale dry-run or blocked panels do not remain on port 8768.
+"""
+
+from __future__ import annotations
+
+import argparse
+import os
+import signal
+import subprocess
+import sys
+from pathlib import Path
+
+
+DEFAULT_PORT = "/dev/serial/by-id/usb-1a86_USB_Single_Serial_5A36029146-if00"
+DEFAULT_HOST = "127.0.0.1"
+DEFAULT_HTTP_PORT = 8768
+DEFAULT_COMMAND_PROFILE = "wheel"
+DEFAULT_LINEAR_SPEED_MPS = 0.18
+DEFAULT_ANGULAR_SPEED_RAD_S = 0.65
+DEFAULT_WHEEL_TURN_SPEED_MPS = 0.26
+
+
+def _run_best_effort(command: list[str]) -> None:
+    subprocess.run(command, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL, check=False)
+
+
+def _stop_existing_drive_panel(http_port: int) -> None:
+    _run_best_effort(["pkill", "-f", "scripts/mobile_base_drive_mode.py"])
+    _run_best_effort(["fuser", "-k", f"{http_port}/tcp"])
+
+
+def _send_final_stop(repo_root: Path, port: str, timeout_sec: float = 0.3) -> None:
+    stop_script = repo_root / "scripts" / "mobile_base_stop.py"
+    if not stop_script.exists():
+        print("[WARN] mobile_base_stop.py not found; skipping final STOP script.")
+        return
+
+    env = os.environ.copy()
+    env["CONFIRM_NEXA_MOBILE_BASE_TEST"] = "RUN"
+
+    command = [
+        sys.executable,
+        str(stop_script),
+        "--port",
+        port,
+        "--read-seconds",
+        str(timeout_sec),
+    ]
+    subprocess.run(command, cwd=str(repo_root), env=env, check=False)
+
+
+def _build_env(args: argparse.Namespace) -> dict[str, str]:
+    env = os.environ.copy()
+
+    env["NEXA_MOBILE_BASE_SERIAL_PORT"] = str(args.port)
+    env["NEXA_DRIVE_MODE_HOST"] = str(args.host)
+    env["NEXA_DRIVE_MODE_HTTP_PORT"] = str(args.http_port)
+    env["NEXA_DRIVE_MODE_FORCE_RESTART"] = "1"
+    env["NEXA_DRIVE_MODE_COMMAND_PROFILE"] = str(args.command_profile)
+    env["NEXA_DRIVE_MODE_LINEAR_SPEED_MPS"] = f"{float(args.linear_speed_mps):.3f}"
+    env["NEXA_DRIVE_MODE_ANGULAR_SPEED_RAD_S"] = f"{float(args.angular_speed_rad_s):.3f}"
+    env["NEXA_DRIVE_MODE_WHEEL_TURN_SPEED_MPS"] = f"{float(args.wheel_turn_speed_mps):.3f}"
+
+    if args.auto_open:
+        env["NEXA_DRIVE_MODE_AUTO_OPEN"] = "1"
+    else:
+        env.pop("NEXA_DRIVE_MODE_AUTO_OPEN", None)
+
+    if args.dry_run:
+        env["NEXA_DRIVE_MODE_DRY_RUN"] = "1"
+        env.pop("NEXA_DRIVE_MODE_ENABLE_MOVEMENT", None)
+        env.pop("CONFIRM_NEXA_MOBILE_BASE_MOVE", None)
+        env.pop("CONFIRM_NEXA_MOBILE_BASE_TEST", None)
+    elif args.enable_movement:
+        env.pop("NEXA_DRIVE_MODE_DRY_RUN", None)
+        env["CONFIRM_NEXA_MOBILE_BASE_TEST"] = "RUN"
+        env["CONFIRM_NEXA_MOBILE_BASE_MOVE"] = "RUN"
+        env["NEXA_DRIVE_MODE_ENABLE_MOVEMENT"] = "1"
+    else:
+        env.pop("NEXA_DRIVE_MODE_DRY_RUN", None)
+        env["CONFIRM_NEXA_MOBILE_BASE_TEST"] = "RUN"
+        env.pop("CONFIRM_NEXA_MOBILE_BASE_MOVE", None)
+        env.pop("NEXA_DRIVE_MODE_ENABLE_MOVEMENT", None)
+
+    return env
+
+
+def build_parser() -> argparse.ArgumentParser:
+    parser = argparse.ArgumentParser(
+        description="Start NeXa main runtime with voice-triggered manual drive mode settings."
+    )
+    parser.add_argument("--main", default="main.py", help="Path to the NeXa main entrypoint.")
+    parser.add_argument("--port", default=DEFAULT_PORT, help="Mobile base serial port.")
+    parser.add_argument("--host", default=DEFAULT_HOST, help="Drive panel bind host.")
+    parser.add_argument("--http-port", type=int, default=DEFAULT_HTTP_PORT, help="Drive panel HTTP port.")
+    parser.add_argument(
+        "--command-profile",
+        choices=("ros", "wheel", "pwm"),
+        default=DEFAULT_COMMAND_PROFILE,
+        help="Mobile base command profile for manual drive mode.",
+    )
+    parser.add_argument("--linear-speed-mps", type=float, default=DEFAULT_LINEAR_SPEED_MPS)
+    parser.add_argument("--angular-speed-rad-s", type=float, default=DEFAULT_ANGULAR_SPEED_RAD_S)
+    parser.add_argument("--wheel-turn-speed-mps", type=float, default=DEFAULT_WHEEL_TURN_SPEED_MPS)
+    parser.add_argument(
+        "--enable-movement",
+        action="store_true",
+        help="Open the real hardware movement gate for the drive panel.",
+    )
+    parser.add_argument(
+        "--dry-run",
+        action="store_true",
+        help="Start voice drive mode in dry-run mode without hardware serial movement.",
+    )
+    parser.add_argument("--no-auto-open", dest="auto_open", action="store_false")
+    parser.set_defaults(auto_open=True)
+    return parser
+
+
+def main(argv: list[str] | None = None) -> int:
+    args = build_parser().parse_args(argv)
+
+    if args.dry_run and args.enable_movement:
+        raise SystemExit("Use either --dry-run or --enable-movement, not both.")
+
+    repo_root = Path.cwd()
+    main_path = (repo_root / str(args.main)).resolve()
+    if not main_path.exists():
+        raise SystemExit(f"Main entrypoint not found: {main_path}")
+
+    _stop_existing_drive_panel(int(args.http_port))
+
+    env = _build_env(args)
+
+    print("[INFO] Starting NeXa runtime with drive mode environment.")
+    print(f"[INFO] Main: {main_path}")
+    print(f"[INFO] Port: {args.port}")
+    print(f"[INFO] Panel: http://{args.host}:{int(args.http_port)}/")
+    print(f"[INFO] Command profile: {args.command_profile}")
+    print(f"[INFO] Linear speed: {float(args.linear_speed_mps):.3f} m/s")
+    print(f"[INFO] Angular speed: {float(args.angular_speed_rad_s):.3f} rad/s")
+    print(f"[INFO] Wheel turn speed: {float(args.wheel_turn_speed_mps):.3f} m/s")
+
+    if args.dry_run:
+        print("[INFO] Drive mode: dry-run, no hardware movement.")
+    elif args.enable_movement:
+        print("[WARN] Drive mode hardware movement is enabled.")
+        print("[WARN] Keep wheels raised until STOP, Space, and Esc are verified.")
+    else:
+        print("[INFO] Hardware serial may open, but movement gate stays closed.")
+
+    process = subprocess.Popen([sys.executable, str(main_path)], cwd=str(repo_root), env=env)
+
+    def _forward_signal(signum: int, _frame: object) -> None:
+        if process.poll() is None:
+            process.send_signal(signum)
+
+    signal.signal(signal.SIGINT, _forward_signal)
+    signal.signal(signal.SIGTERM, _forward_signal)
+
+    try:
+        return int(process.wait())
+    finally:
+        _stop_existing_drive_panel(int(args.http_port))
+        if args.enable_movement and not args.dry_run:
+            print("[INFO] Sending final STOP after NeXa runtime exit.")
+            _send_final_stop(repo_root, str(args.port))
+
+
+if __name__ == "__main__":
+    raise SystemExit(main(sys.argv[1:]))
