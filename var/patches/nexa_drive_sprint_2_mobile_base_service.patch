new file mode 100644
index 0000000..9f330b9
--- /dev/null
+++ b/modules/devices/mobile_base/safety.py
@@ -0,0 +1,120 @@
+from __future__ import annotations
+
+import math
+import os
+from dataclasses import dataclass
+
+
+DEFAULT_MOVEMENT_CONFIRM_ENV = "CONFIRM_NEXA_MOBILE_BASE_MOVE"
+DEFAULT_MOVEMENT_CONFIRM_VALUE = "RUN"
+
+
+class MobileBaseSafetyError(RuntimeError):
+    """Raised when a requested mobile base movement is not allowed safely."""
+
+
+@dataclass(frozen=True, slots=True)
+class MobileBaseSafetyPolicy:
+    """
+    Central safety policy for mobile base movement commands.
+
+    STOP commands are always allowed. Any non-zero movement command is blocked
+    unless movement_enabled is true and the optional environment gate is open.
+    """
+
+    movement_enabled: bool = False
+    require_movement_confirm_env: bool = True
+    movement_confirm_env: str = DEFAULT_MOVEMENT_CONFIRM_ENV
+    movement_confirm_value: str = DEFAULT_MOVEMENT_CONFIRM_VALUE
+    default_linear_speed_mps: float = 0.04
+    default_angular_speed_rad_s: float = 0.18
+    max_linear_speed_mps: float = 0.08
+    max_angular_speed_rad_s: float = 0.25
+    max_command_duration_ms: int = 350
+    deadman_timeout_ms: int = 250
+
+    def assert_stop_is_allowed(self) -> None:
+        """STOP is always allowed and intentionally has no hardware gate."""
+
+    def assert_movement_is_allowed(self) -> None:
+        """Validate all gates required for non-zero movement."""
+
+        if not self.movement_enabled:
+            raise MobileBaseSafetyError("Mobile base movement is disabled by safety policy.")
+        if self.require_movement_confirm_env:
+            actual_value = os.environ.get(self.movement_confirm_env)
+            if actual_value != self.movement_confirm_value:
+                raise MobileBaseSafetyError(
+                    "Mobile base movement gate is closed. "
+                    f"Set {self.movement_confirm_env}={self.movement_confirm_value} only for a controlled test."
+                )
+
+    def clamp_linear_speed(self, value: float) -> float:
+        """Clamp linear speed to the configured symmetric safety range."""
+
+        return _clamp_float(
+            value,
+            lower=-abs(self.max_linear_speed_mps),
+            upper=abs(self.max_linear_speed_mps),
+            field_name="linear_x_mps",
+        )
+
+    def clamp_angular_speed(self, value: float) -> float:
+        """Clamp angular speed to the configured symmetric safety range."""
+
+        return _clamp_float(
+            value,
+            lower=-abs(self.max_angular_speed_rad_s),
+            upper=abs(self.max_angular_speed_rad_s),
+            field_name="angular_z_rad_s",
+        )
+
+    def clamp_duration_ms(self, value: int | float) -> int:
+        """Clamp a requested movement duration to the configured maximum."""
+
+        duration = int(value)
+        if duration < 0:
+            raise MobileBaseSafetyError("duration_ms must not be negative")
+        return min(duration, int(self.max_command_duration_ms))
+
+    def validate_velocity_request(
+        self,
+        *,
+        linear_x_mps: float,
+        angular_z_rad_s: float,
+    ) -> tuple[float, float]:
+        """
+        Validate and clamp a velocity request.
+
+        A zero velocity request is treated as STOP and is always allowed.
+        """
+
+        linear = self.clamp_linear_speed(linear_x_mps)
+        angular = self.clamp_angular_speed(angular_z_rad_s)
+        if is_zero_velocity(linear_x_mps=linear, angular_z_rad_s=angular):
+            self.assert_stop_is_allowed()
+            return 0.0, 0.0
+        self.assert_movement_is_allowed()
+        return linear, angular
+
+
+def is_zero_velocity(*, linear_x_mps: float, angular_z_rad_s: float) -> bool:
+    """Return true when a velocity request is effectively STOP."""
+
+    return abs(float(linear_x_mps)) < 1e-9 and abs(float(angular_z_rad_s)) < 1e-9
+
+
+def _clamp_float(value: float, *, lower: float, upper: float, field_name: str) -> float:
+    number = float(value)
+    if not math.isfinite(number):
+        raise MobileBaseSafetyError(f"{field_name} must be finite")
+    return max(float(lower), min(float(upper), number))
+
+
+__all__ = [
+    "DEFAULT_MOVEMENT_CONFIRM_ENV",
+    "DEFAULT_MOVEMENT_CONFIRM_VALUE",
+    "MobileBaseSafetyError",
+    "MobileBaseSafetyPolicy",
+    "is_zero_velocity",
+]
