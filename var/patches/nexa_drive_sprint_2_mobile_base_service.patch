new file mode 100755
index 0000000..0f4b527
--- /dev/null
+++ b/scripts/mobile_base_stop.py
@@ -0,0 +1,106 @@
+#!/usr/bin/env python3
+from __future__ import annotations
+
+import argparse
+import os
+import sys
+from pathlib import Path
+
+PROJECT_ROOT = Path(__file__).resolve().parents[1]
+if str(PROJECT_ROOT) not in sys.path:
+    sys.path.insert(0, str(PROJECT_ROOT))
+
+from modules.devices.mobile_base import (  # noqa: E402
+    DEFAULT_BAUDRATE,
+    DEFAULT_TIMEOUT_SEC,
+    DryRunSerialTransport,
+    MobileBaseController,
+    MobileBaseSafetyPolicy,
+    PySerialLineTransport,
+    choose_serial_port,
+)
+
+
+CONFIRM_ENV_VAR = "CONFIRM_NEXA_MOBILE_BASE_TEST"
+CONFIRM_ENV_VALUE = "RUN"
+
+
+def _hardware_gate_is_open() -> bool:
+    return os.environ.get(CONFIRM_ENV_VAR) == CONFIRM_ENV_VALUE
+
+
+def build_parser() -> argparse.ArgumentParser:
+    parser = argparse.ArgumentParser(
+        description="Send a safe STOP sequence through the NeXa mobile base controller."
+    )
+    parser.add_argument("--dry-run", action="store_true", help="Do not open hardware serial.")
+    parser.add_argument("--port", type=str, default=None, help="Serial device path.")
+    parser.add_argument("--baudrate", type=int, default=DEFAULT_BAUDRATE)
+    parser.add_argument("--timeout-sec", type=float, default=DEFAULT_TIMEOUT_SEC)
+    parser.add_argument("--read-seconds", type=float, default=0.2)
+    parser.add_argument("--stop-repeat", type=int, default=3)
+    return parser
+
+
+def main(argv: list[str] | None = None) -> int:
+    args = build_parser().parse_args(argv)
+
+    if args.dry_run:
+        selected_port = args.port or "dry-run:auto"
+        transport = DryRunSerialTransport()
+        print("[DRY-RUN] STOP will be sent to the in-memory transport only.")
+    else:
+        if not _hardware_gate_is_open():
+            print(
+                f"[ERROR] Hardware gate is closed. Set {CONFIRM_ENV_VAR}={CONFIRM_ENV_VALUE} "
+                "to send STOP to real hardware."
+            )
+            return 2
+        selected_port = choose_serial_port(explicit_port=args.port)
+        transport = PySerialLineTransport(
+            port=selected_port,
+            baudrate=int(args.baudrate),
+            timeout_sec=float(args.timeout_sec),
+        )
+
+    print(f"[INFO] Selected port: {selected_port}")
+    print("[INFO] Command: STOP only")
+
+    controller = MobileBaseController(
+        transport=transport,
+        safety_policy=MobileBaseSafetyPolicy(movement_enabled=False),
+        stop_repeat=int(args.stop_repeat),
+    )
+
+    try:
+        controller.open()
+        written_lines = controller.stop(reason="manual_stop_script")
+        for line in written_lines:
+            prefix = "[DRY-RUN]" if args.dry_run else "[WRITE]"
+            print(f"{prefix} {line}")
+        for response in controller.read_available_lines(duration_sec=max(0.0, float(args.read_seconds))):
+            print(f"[READ] {response}")
+        print("[OK] Mobile base STOP completed.")
+        return 0
+    except PermissionError:
+        print("[ERROR] Permission denied when opening the serial port.")
+        return 3
+    except KeyboardInterrupt:
+        print("[WARN] Interrupted. Attempting final STOP before closing.")
+        try:
+            controller.stop(reason="keyboard_interrupt")
+        except Exception:
+            pass
+        return 130
+    except Exception as error:
+        print(f"[ERROR] {error}")
+        return 4
+    finally:
+        try:
+            controller.close()
+        except Exception:
+            pass
+
+
+if __name__ == "__main__":
+    raise SystemExit(main(sys.argv[1:]))
