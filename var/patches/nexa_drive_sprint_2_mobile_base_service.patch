diff --git a/modules/devices/mobile_base/controller.py b/modules/devices/mobile_base/controller.py
new file mode 100644
index 0000000..b7f4331
--- /dev/null
+++ b/modules/devices/mobile_base/controller.py
@@ -0,0 +1,155 @@
+from __future__ import annotations
+
+import time
+from typing import Protocol
+
+from .commands import build_ros_velocity_command, build_stop_sequence, serialize_json_line
+from .safety import MobileBaseSafetyPolicy, is_zero_velocity
+
+
+class LineTransport(Protocol):
+    """Minimal line-oriented transport used by the mobile base controller."""
+
+    def open(self) -> None:
+        ...
+
+    def write_line(self, line: str) -> None:
+        ...
+
+    def read_available_lines(self, *, duration_sec: float = 0.0) -> list[str]:
+        ...
+
+    def close(self) -> None:
+        ...
+
+
+class MobileBaseController:
+    """
+    Safe high-level controller for the Waveshare mobile base.
+
+    The controller does not discover ports and does not know runtime policy. It
+    only converts approved high-level actions into line-based JSON commands.
+    """
+
+    def __init__(
+        self,
+        *,
+        transport: LineTransport,
+        safety_policy: MobileBaseSafetyPolicy | None = None,
+        stop_repeat: int = 3,
+        stop_interval_sec: float = 0.04,
+    ) -> None:
+        self.transport = transport
+        self.safety_policy = safety_policy or MobileBaseSafetyPolicy()
+        self.stop_repeat = int(stop_repeat)
+        self.stop_interval_sec = max(0.0, float(stop_interval_sec))
+        self._opened = False
+        self._last_motion_monotonic: float | None = None
+        self._deadman_stop_sent = False
+
+    @property
+    def opened(self) -> bool:
+        return self._opened
+
+    def open(self) -> None:
+        self.transport.open()
+        self._opened = True
+
+    def close(self) -> None:
+        if self._opened:
+            try:
+                self.stop(reason="controller_close")
+            finally:
+                self.transport.close()
+                self._opened = False
+        else:
+            self.transport.close()
+
+    def stop(self, *, reason: str = "stop") -> list[str]:
+        """Send a repeated STOP sequence. STOP is always allowed."""
+
+        del reason
+        self.safety_policy.assert_stop_is_allowed()
+        written_lines: list[str] = []
+        for command in build_stop_sequence(repeat=self.stop_repeat):
+            line = serialize_json_line(command)
+            self.transport.write_line(line)
+            written_lines.append(line.rstrip("\n"))
+            if self.stop_interval_sec > 0.0:
+                time.sleep(self.stop_interval_sec)
+        self._last_motion_monotonic = None
+        self._deadman_stop_sent = False
+        return written_lines
+
+    def send_velocity(
+        self,
+        *,
+        linear_x_mps: float,
+        angular_z_rad_s: float,
+    ) -> str:
+        """Validate, clamp and send one velocity command."""
+
+        linear, angular = self.safety_policy.validate_velocity_request(
+            linear_x_mps=linear_x_mps,
+            angular_z_rad_s=angular_z_rad_s,
+        )
+        command = build_ros_velocity_command(
+            linear_x_mps=linear,
+            angular_z_rad_s=angular,
+        )
+        line = serialize_json_line(command)
+        self.transport.write_line(line)
+
+        if is_zero_velocity(linear_x_mps=linear, angular_z_rad_s=angular):
+            self._last_motion_monotonic = None
+            self._deadman_stop_sent = False
+        else:
+            self._last_motion_monotonic = time.monotonic()
+            self._deadman_stop_sent = False
+        return line.rstrip("\n")
+
+    def drive_forward(self, *, speed_mps: float | None = None) -> str:
+        speed = self.safety_policy.default_linear_speed_mps if speed_mps is None else speed_mps
+        return self.send_velocity(linear_x_mps=abs(float(speed)), angular_z_rad_s=0.0)
+
+    def drive_backward(self, *, speed_mps: float | None = None) -> str:
+        speed = self.safety_policy.default_linear_speed_mps if speed_mps is None else speed_mps
+        return self.send_velocity(linear_x_mps=-abs(float(speed)), angular_z_rad_s=0.0)
+
+    def rotate_left(self, *, speed_rad_s: float | None = None) -> str:
+        speed = self.safety_policy.default_angular_speed_rad_s if speed_rad_s is None else speed_rad_s
+        return self.send_velocity(linear_x_mps=0.0, angular_z_rad_s=abs(float(speed)))
+
+    def rotate_right(self, *, speed_rad_s: float | None = None) -> str:
+        speed = self.safety_policy.default_angular_speed_rad_s if speed_rad_s is None else speed_rad_s
+        return self.send_velocity(linear_x_mps=0.0, angular_z_rad_s=-abs(float(speed)))
+
+    def check_deadman(self, *, now_monotonic: float | None = None) -> bool:
+        """
+        Send STOP when a movement command is not refreshed in time.
+
+        Returns true when this call sent a watchdog STOP.
+        """
+
+        if self._last_motion_monotonic is None or self._deadman_stop_sent:
+            return False
+        now = time.monotonic() if now_monotonic is None else float(now_monotonic)
+        elapsed_ms = (now - self._last_motion_monotonic) * 1000.0
+        if elapsed_ms < float(self.safety_policy.deadman_timeout_ms):
+            return False
+        self.stop(reason="deadman_timeout")
+        self._deadman_stop_sent = True
+        return True
+
+    def read_available_lines(self, *, duration_sec: float = 0.0) -> list[str]:
+        return self.transport.read_available_lines(duration_sec=duration_sec)
+
+    def __enter__(self) -> "MobileBaseController":
+        self.open()
+        return self
+
+    def __exit__(self, exc_type: object, exc: object, tb: object) -> None:
+        self.close()
+
+
+__all__ = ["LineTransport", "MobileBaseController"]
