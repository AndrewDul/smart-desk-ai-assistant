+def main() -> int:
+    for relative_path, content in FILES.items():
+        path = PROJECT_ROOT / relative_path
+        path.parent.mkdir(parents=True, exist_ok=True)
+        path.write_text(content, encoding="utf-8")
+        print(f"[REPAIR] wrote {relative_path}")
+
+    required_modules = [
+        "modules.devices.mobile_base",
+        "modules.runtime.drive_mode",
+        "modules.core.command_intents.command_intent_resolver",
+        "modules.core.flows.action_flow.orchestrator",
+    ]
+    for module_name in required_modules:
+        importlib.import_module(module_name)
+        print(f"[REPAIR] import ok: {module_name}")
+    print("[REPAIR OK] Mobile base drive mode runtime files are consistent.")
+    return 0
+
+
+if __name__ == "__main__":
+    raise SystemExit(main())
