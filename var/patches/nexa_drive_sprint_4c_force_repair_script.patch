+    'modules/runtime/drive_mode/keyboard_mapping.py': 'from __future__ import annotations\n\nfrom enum import Enum\n\n\nclass DriveModeAction(str, Enum):\n    """High-level manual drive actions produced by keyboard input."""\n\n    FORWARD = "forward"\n    BACKWARD = "backward"\n    ROTATE_LEFT = "rotate_left"\n    ROTATE_RIGHT = "rotate_right"\n    FORWARD_LEFT = "forward_left"\n    FORWARD_RIGHT = "forward_right"\n    BACKWARD_LEFT = "backward_left"\n    BACKWARD_RIGHT = "backward_right"\n    EMERGENCY_STOP = "emergency_stop"\n    EXIT = "exit"\n    UNKNOWN = "unknown"\n\n\n_KEY_ALIASES: dict[str, DriveModeAction] = {\n    "w": DriveModeAction.FORWARD,\n    "arrowup": DriveModeAction.FORWARD,\n    "s": DriveModeAction.BACKWARD,\n    "arrowdown": DriveModeAction.BACKWARD,\n    "a": DriveModeAction.ROTATE_LEFT,\n    "arrowleft": DriveModeAction.ROTATE_LEFT,\n    "d": DriveModeAction.ROTATE_RIGHT,\n    "arrowright": DriveModeAction.ROTATE_RIGHT,\n    " ": DriveModeAction.EMERGENCY_STOP,\n    "space": DriveModeAction.EMERGENCY_STOP,\n    "spacebar": DriveModeAction.EMERGENCY_STOP,\n    "escape": DriveModeAction.EXIT,\n    "esc": DriveModeAction.EXIT,\n}\n\n\nMOTION_ACTIONS = frozenset(\n    {\n        DriveModeAction.FORWARD,\n        DriveModeAction.BACKWARD,\n        DriveModeAction.ROTATE_LEFT,\n        DriveModeAction.ROTATE_RIGHT,\n        DriveModeAction.FORWARD_LEFT,\n        DriveModeAction.FORWARD_RIGHT,\n        DriveModeAction.BACKWARD_LEFT,\n        DriveModeAction.BACKWARD_RIGHT,\n    }\n)\n\n\ndef normalize_key(raw_key: str) -> str:\n    """Normalize browser and terminal key names to one stable representation."""\n\n    raw = str(raw_key or "")\n    if raw == " ":\n        return " "\n    key = raw.strip()\n    if len(key) == 1:\n        return key.lower()\n    return key.replace(" ", "").lower()\n\n\ndef map_keyboard_event(raw_key: str) -> DriveModeAction:\n    """Map a raw keyboard key to a drive action."""\n\n    return _KEY_ALIASES.get(normalize_key(raw_key), DriveModeAction.UNKNOWN)\n\n\n__all__ = ["DriveModeAction", "MOTION_ACTIONS", "map_keyboard_event", "normalize_key"]\n',
+    'modules/runtime/drive_mode/voice_launcher.py': 'from __future__ import annotations\n\nimport os\nimport socket\nimport subprocess\nimport sys\nimport time\nfrom dataclasses import dataclass\nfrom pathlib import Path\nfrom typing import Mapping\n\nfrom modules.devices.mobile_base import (\n    DEFAULT_MOVEMENT_CONFIRM_ENV,\n    DEFAULT_MOVEMENT_CONFIRM_VALUE,\n)\n\n\nCONFIRM_TEST_ENV_VAR = "CONFIRM_NEXA_MOBILE_BASE_TEST"\nCONFIRM_TEST_ENV_VALUE = "RUN"\nDRIVE_MODE_HOST_ENV = "NEXA_DRIVE_MODE_HOST"\nDRIVE_MODE_HTTP_PORT_ENV = "NEXA_DRIVE_MODE_HTTP_PORT"\nDRIVE_MODE_DRY_RUN_ENV = "NEXA_DRIVE_MODE_DRY_RUN"\nDRIVE_MODE_ENABLE_MOVEMENT_ENV = "NEXA_DRIVE_MODE_ENABLE_MOVEMENT"\nDRIVE_MODE_SERIAL_PORT_ENV = "NEXA_MOBILE_BASE_SERIAL_PORT"\nDRIVE_MODE_LINEAR_SPEED_ENV = "NEXA_DRIVE_MODE_LINEAR_SPEED_MPS"\nDRIVE_MODE_ANGULAR_SPEED_ENV = "NEXA_DRIVE_MODE_ANGULAR_SPEED_RAD_S"\nDRIVE_MODE_LOG_PATH_ENV = "NEXA_DRIVE_MODE_LOG_PATH"\nDRIVE_MODE_AUTO_OPEN_ENV = "NEXA_DRIVE_MODE_AUTO_OPEN"\n\n\n@dataclass(frozen=True, slots=True)\nclass DriveModeLaunchConfig:\n    """Configuration used when Voice Runtime starts manual drive mode."""\n\n    project_root: Path\n    host: str = "127.0.0.1"\n    http_port: int = 8768\n    dry_run: bool = False\n    serial_port: str = ""\n    enable_movement: bool = False\n    movement_requested: bool = False\n    linear_speed_mps: float = 0.15\n    angular_speed_rad_s: float = 0.30\n    log_path: Path | None = None\n    auto_open: bool = True\n\n    @property\n    def panel_url(self) -> str:\n        host = "127.0.0.1" if self.host in {"", "0.0.0.0"} else self.host\n        return f"http://{host}:{int(self.http_port)}/"\n\n    @property\n    def status_host(self) -> str:\n        return "127.0.0.1" if self.host in {"", "0.0.0.0"} else self.host\n\n\n@dataclass(frozen=True, slots=True)\nclass DriveModeLaunchResult:\n    """Result of a voice-triggered drive mode launch attempt."""\n\n    ok: bool\n    status: str\n    message: str\n    panel_url: str = ""\n    command: tuple[str, ...] = ()\n    pid: int | None = None\n    movement_enabled: bool = False\n    log_path: str = ""\n\n\ndef _truthy(value: object) -> bool:\n    return str(value or "").strip().lower() in {"1", "true", "yes", "y", "on", "run"}\n\n\ndef _is_falsey(value: object) -> bool:\n    return str(value or "").strip().lower() in {"0", "false", "no", "n", "off", "disable", "disabled"}\n\n\ndef _safe_int(value: object, default: int) -> int:\n    try:\n        return int(str(value).strip())\n    except Exception:\n        return int(default)\n\n\ndef _safe_float(value: object, default: float) -> float:\n    try:\n        return float(str(value).strip())\n    except Exception:\n        return float(default)\n\n\ndef build_drive_mode_launch_config_from_env(\n    *,\n    env: Mapping[str, str] | None = None,\n    project_root: Path | None = None,\n) -> DriveModeLaunchConfig:\n    """Build a safe launch config from runtime environment variables."""\n\n    source = dict(os.environ if env is None else env)\n    root = project_root or Path(__file__).resolve().parents[3]\n    movement_requested = _truthy(source.get(DRIVE_MODE_ENABLE_MOVEMENT_ENV))\n    movement_gate_open = source.get(DEFAULT_MOVEMENT_CONFIRM_ENV) == DEFAULT_MOVEMENT_CONFIRM_VALUE\n    enable_movement = bool(movement_requested and movement_gate_open)\n    configured_log = str(source.get(DRIVE_MODE_LOG_PATH_ENV, "")).strip()\n    log_path = Path(configured_log) if configured_log else root / "var" / "log" / "mobile_base_drive_mode_voice.log"\n\n    return DriveModeLaunchConfig(\n        project_root=root,\n        host=str(source.get(DRIVE_MODE_HOST_ENV, "127.0.0.1") or "127.0.0.1"),\n        http_port=_safe_int(source.get(DRIVE_MODE_HTTP_PORT_ENV), 8768),\n        dry_run=_truthy(source.get(DRIVE_MODE_DRY_RUN_ENV)),\n        serial_port=str(source.get(DRIVE_MODE_SERIAL_PORT_ENV, "") or ""),\n        enable_movement=enable_movement,\n        movement_requested=movement_requested,\n        linear_speed_mps=_safe_float(source.get(DRIVE_MODE_LINEAR_SPEED_ENV), 0.15),\n        angular_speed_rad_s=_safe_float(source.get(DRIVE_MODE_ANGULAR_SPEED_ENV), 0.30),\n        log_path=log_path,\n        auto_open=not _is_falsey(source.get(DRIVE_MODE_AUTO_OPEN_ENV)),\n    )\n\n\ndef build_drive_mode_launch_command(config: DriveModeLaunchConfig) -> tuple[str, ...]:\n    """Return the subprocess command used to run the web drive panel."""\n\n    script_path = config.project_root / "scripts" / "mobile_base_drive_mode.py"\n    command: list[str] = [\n        sys.executable,\n        str(script_path),\n        "--host",\n        str(config.host),\n        "--http-port",\n        str(int(config.http_port)),\n        "--linear-speed-mps",\n        f"{float(config.linear_speed_mps):.3f}",\n        "--angular-speed-rad-s",\n        f"{float(config.angular_speed_rad_s):.3f}",\n    ]\n    if config.dry_run:\n        command.append("--dry-run")\n    if config.serial_port:\n        command.extend(["--port", str(config.serial_port)])\n    if config.enable_movement:\n        command.append("--enable-movement")\n    return tuple(command)\n\n\ndef _is_http_port_alive(*, host: str, port: int, timeout_sec: float = 0.15) -> bool:\n    try:\n        with socket.create_connection((host, int(port)), timeout=float(timeout_sec)):\n            return True\n    except OSError:\n        return False\n\n\ndef _auto_open_panel(*, config: DriveModeLaunchConfig, log_path: Path) -> None:\n    """Best-effort local browser opener for Raspberry Pi desktop sessions."""\n\n    if not config.auto_open:\n        return\n    if not os.environ.get("DISPLAY") and not os.environ.get("WAYLAND_DISPLAY"):\n        return\n    try:\n        with log_path.open("a", encoding="utf-8") as log_file:\n            log_file.write(f"[VOICE-LAUNCH] Auto-opening panel: {config.panel_url}\\n")\n            subprocess.Popen(\n                ("xdg-open", config.panel_url),\n                cwd=str(config.project_root),\n                stdout=log_file,\n                stderr=subprocess.STDOUT,\n                start_new_session=True,\n            )\n    except Exception as error:\n        try:\n            with log_path.open("a", encoding="utf-8") as log_file:\n                log_file.write(f"[VOICE-LAUNCH] Auto-open failed: {error}\\n")\n        except Exception:\n            pass\n\n\nclass DriveModeVoiceLauncher:\n    """Starts the manual drive panel without blocking Voice Runtime."""\n\n    def __init__(self, *, config: DriveModeLaunchConfig | None = None) -> None:\n        self.config = config or build_drive_mode_launch_config_from_env()\n\n    def launch(self) -> DriveModeLaunchResult:\n        config = self.config\n        if _is_http_port_alive(host=config.status_host, port=config.http_port):\n            log_path = config.log_path or (config.project_root / "var" / "log" / "mobile_base_drive_mode_voice.log")\n            log_path.parent.mkdir(parents=True, exist_ok=True)\n            _auto_open_panel(config=config, log_path=log_path)\n            return DriveModeLaunchResult(\n                ok=True,\n                status="already_running",\n                message="Drive mode panel is already running.",\n                panel_url=config.panel_url,\n                movement_enabled=config.enable_movement,\n                log_path=str(config.log_path or ""),\n            )\n        if not config.dry_run and os.environ.get(CONFIRM_TEST_ENV_VAR) != CONFIRM_TEST_ENV_VALUE:\n            return DriveModeLaunchResult(\n                ok=False,\n                status="hardware_gate_closed",\n                message=(\n                    f"Hardware gate is closed. Set {CONFIRM_TEST_ENV_VAR}={CONFIRM_TEST_ENV_VALUE} "\n                    "before voice-starting drive mode against the real mobile base."\n                ),\n                panel_url=config.panel_url,\n                movement_enabled=False,\n                log_path=str(config.log_path or ""),\n            )\n        command = build_drive_mode_launch_command(config)\n        log_path = config.log_path or (config.project_root / "var" / "log" / "mobile_base_drive_mode_voice.log")\n        log_path.parent.mkdir(parents=True, exist_ok=True)\n        with log_path.open("a", encoding="utf-8") as log_file:\n            log_file.write("\\n[VOICE-LAUNCH] Starting drive mode panel\\n")\n            log_file.write("[VOICE-LAUNCH] Command: " + " ".join(command) + "\\n")\n            process = subprocess.Popen(\n                command,\n                cwd=str(config.project_root),\n                stdout=log_file,\n                stderr=subprocess.STDOUT,\n                start_new_session=True,\n            )\n        time.sleep(0.25)\n        if process.poll() is not None:\n            return DriveModeLaunchResult(\n                ok=False,\n                status="process_exited",\n                message="Drive mode process exited immediately. Check the drive mode voice log.",\n                panel_url=config.panel_url,\n                command=command,\n                pid=process.pid,\n                movement_enabled=config.enable_movement,\n                log_path=str(log_path),\n            )\n        _auto_open_panel(config=config, log_path=log_path)\n        return DriveModeLaunchResult(\n            ok=True,\n            status="started",\n            message="Drive mode panel started.",\n            panel_url=config.panel_url,\n            command=command,\n            pid=process.pid,\n            movement_enabled=config.enable_movement,\n            log_path=str(log_path),\n        )\n\n\n__all__ = [\n    "DriveModeLaunchConfig",\n    "DriveModeLaunchResult",\n    "DriveModeVoiceLauncher",\n    "DRIVE_MODE_AUTO_OPEN_ENV",\n    "build_drive_mode_launch_command",\n    "build_drive_mode_launch_config_from_env",\n]\n',
+    'scripts/mobile_base_drive_mode.py': '#!/usr/bin/env python3\nfrom __future__ import annotations\n\nimport argparse\nimport json\nimport os\nimport signal\nimport sys\nimport threading\nimport time\nfrom http.server import BaseHTTPRequestHandler, ThreadingHTTPServer\nfrom pathlib import Path\nfrom typing import Any\n\nPROJECT_ROOT = Path(__file__).resolve().parents[1]\nif str(PROJECT_ROOT) not in sys.path:\n    sys.path.insert(0, str(PROJECT_ROOT))\n\nfrom modules.devices.mobile_base import (  # noqa: E402\n    DEFAULT_BAUDRATE,\n    DEFAULT_TIMEOUT_SEC,\n    DEFAULT_MOVEMENT_CONFIRM_ENV,\n    DEFAULT_MOVEMENT_CONFIRM_VALUE,\n    DryRunSerialTransport,\n    MobileBaseController,\n    MobileBaseSafetyPolicy,\n    PySerialLineTransport,\n    choose_serial_port,\n)\nfrom modules.runtime.drive_mode import DriveModeService  # noqa: E402\n\n\nCONFIRM_TEST_ENV_VAR = "CONFIRM_NEXA_MOBILE_BASE_TEST"\nCONFIRM_TEST_ENV_VALUE = "RUN"\nDEFAULT_HTTP_HOST = "127.0.0.1"\nDEFAULT_HTTP_PORT = 8768\nDEFAULT_LINEAR_SPEED_MPS = 0.15\nDEFAULT_ANGULAR_SPEED_RAD_S = 0.30\nMAX_LINEAR_SPEED_MPS = 0.20\nMAX_ANGULAR_SPEED_RAD_S = 0.45\n\n\nHTML_PAGE = """<!doctype html>\n<html lang="en">\n<head>\n  <meta charset="utf-8">\n  <meta name="viewport" content="width=device-width, initial-scale=1">\n  <title>NeXa Drive Mode</title>\n  <style>\n    :root { color-scheme: dark; font-family: system-ui, -apple-system, BlinkMacSystemFont, sans-serif; }\n    body { margin: 0; min-height: 100vh; background: #0b0d12; color: #f4f7fb; display: grid; place-items: center; }\n    main { width: min(720px, calc(100vw - 32px)); padding: 28px; border: 1px solid #252b36; border-radius: 24px; background: #111722; box-shadow: 0 24px 80px rgba(0,0,0,.45); }\n    h1 { margin: 0 0 10px; font-size: 28px; }\n    p { color: #aeb8c8; line-height: 1.55; }\n    .grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 12px; margin: 24px 0; }\n    .key { border: 1px solid #334052; border-radius: 18px; padding: 22px 10px; text-align: center; background: #182131; font-size: 24px; font-weight: 750; user-select: none; }\n    .key.active { outline: 3px solid #8ab4ff; }\n    .empty { visibility: hidden; }\n    button { width: 100%; border: 0; border-radius: 18px; padding: 18px; font-size: 18px; font-weight: 800; color: white; background: #9b1c31; cursor: pointer; }\n    code { color: #d8e4ff; }\n    pre { min-height: 90px; max-height: 180px; overflow: auto; padding: 16px; border-radius: 16px; background: #080b10; color: #c8d6ea; }\n  </style>\n</head>\n<body>\n  <main>\n    <h1>NeXa Drive Mode</h1>\n    <p>Use <code>W/A/S/D</code> or arrow keys. Release the key to STOP. <code>Space</code> sends emergency STOP. <code>Esc</code> stops and asks the server to exit drive mode.</p>\n    <div class="grid">\n      <div class="empty"></div><div class="key" data-key="w">W</div><div class="empty"></div>\n      <div class="key" data-key="a">A</div><div class="key" data-key="s">S</div><div class="key" data-key="d">D</div>\n    </div>\n    <button id="stop">EMERGENCY STOP</button>\n    <p id="status">Status: ready</p>\n    <pre id="log"></pre>\n  </main>\n<script>\nconst pressed = new Set();\nconst activeByKey = {"w":"w", "a":"a", "s":"s", "d":"d", "ArrowUp":"w", "ArrowLeft":"a", "ArrowDown":"s", "ArrowRight":"d"};\nconst log = document.getElementById("log");\nconst statusBox = document.getElementById("status");\nfunction append(message) {\n  const time = new Date().toLocaleTimeString();\n  log.textContent = `[${time}] ${message}\\n` + log.textContent;\n}\nasync function postJSON(path, payload) {\n  const response = await fetch(path, {\n    method: \'POST\',\n    headers: {\'Content-Type\': \'application/json\'},\n    body: JSON.stringify(payload)\n  });\n  const data = await response.json();\n  statusBox.textContent = `Status: ${data.ok ? \'ok\' : \'error\'} ${data.action || \'\'}`;\n  append(JSON.stringify(data));\n  return data;\n}\nasync function send(event, key) {\n  return postJSON(\'/api/key\', {event, key});\n}\nasync function sendState() {\n  return postJSON(\'/api/keys\', {keys: Array.from(pressed)});\n}\nfunction mark(key, active) {\n  const mapped = activeByKey[key] || key.toLowerCase();\n  const node = document.querySelector(`[data-key="${mapped}"]`);\n  if (node) node.classList.toggle(\'active\', active);\n}\ndocument.addEventListener(\'keydown\', async (event) => {\n  if (["w", "a", "s", "d", " ", "Escape", "ArrowUp", "ArrowLeft", "ArrowDown", "ArrowRight"].includes(event.key)) {\n    event.preventDefault();\n  }\n  if (event.key === \' \') {\n    await send(\'down\', \'space\');\n    return;\n  }\n  if (event.key === \'Escape\') {\n    await send(\'down\', \'escape\');\n    return;\n  }\n  const key = event.key.length === 1 ? event.key.toLowerCase() : event.key;\n  if (!pressed.has(key)) pressed.add(key);\n  mark(key, true);\n  if (["w", "a", "s", "d", "ArrowUp", "ArrowLeft", "ArrowDown", "ArrowRight"].includes(key)) {\n    await sendState();\n  }\n});\ndocument.addEventListener(\'keyup\', async (event) => {\n  const key = event.key.length === 1 ? event.key.toLowerCase() : event.key;\n  pressed.delete(key);\n  mark(key, false);\n  if (["w", "a", "s", "d", "ArrowUp", "ArrowLeft", "ArrowDown", "ArrowRight"].includes(key)) {\n    await sendState();\n  }\n});\nsetInterval(() => {\n  if (pressed.size > 0) {\n    sendState().catch(() => {});\n  }\n}, 90);\ndocument.getElementById(\'stop\').addEventListener(\'click\', () => send(\'down\', \'space\'));\nwindow.addEventListener(\'blur\', () => send(\'down\', \'space\').catch(() => {}));\nappend(\'Drive panel loaded. Keep wheels raised for hardware tests.\');\n</script>\n</body>\n</html>\n"""\n\n\nclass DriveModeHTTPServer(ThreadingHTTPServer):\n    service: DriveModeService\n    should_exit: threading.Event\n\n\ndef _json_response(handler: BaseHTTPRequestHandler, payload: dict[str, Any], *, status: int = 200) -> None:\n    encoded = json.dumps(payload, separators=(",", ":")).encode("utf-8")\n    handl