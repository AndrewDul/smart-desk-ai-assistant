+    'modules/devices/mobile_base/controller.py': 'from __future__ import annotations\n\nimport time\nfrom typing import Protocol\n\nfrom .commands import build_ros_velocity_command, build_stop_sequence, serialize_json_line\nfrom .safety import MobileBaseSafetyPolicy, is_zero_velocity\n\n\nclass LineTransport(Protocol):\n    """Minimal line-oriented transport used by the mobile base controller."""\n\n    def open(self) -> None:\n        ...\n\n    def write_line(self, line: str) -> None:\n        ...\n\n    def read_available_lines(self, *, duration_sec: float = 0.0) -> list[str]:\n        ...\n\n    def close(self) -> None:\n        ...\n\n\nclass MobileBaseController:\n    """\n    Safe high-level controller for the Waveshare mobile base.\n\n    The controller does not discover ports and does not know runtime policy. It\n    only converts approved high-level actions into line-based JSON commands.\n    """\n\n    def __init__(\n        self,\n        *,\n        transport: LineTransport,\n        safety_policy: MobileBaseSafetyPolicy | None = None,\n        stop_repeat: int = 3,\n        stop_interval_sec: float = 0.04,\n    ) -> None:\n        self.transport = transport\n        self.safety_policy = safety_policy or MobileBaseSafetyPolicy()\n        self.stop_repeat = int(stop_repeat)\n        self.stop_interval_sec = max(0.0, float(stop_interval_sec))\n        self._opened = False\n        self._last_motion_monotonic: float | None = None\n        self._deadman_stop_sent = False\n\n    @property\n    def opened(self) -> bool:\n        return self._opened\n\n    def open(self) -> None:\n        self.transport.open()\n        self._opened = True\n\n    def close(self) -> None:\n        if self._opened:\n            try:\n                self.stop(reason="controller_close")\n            finally:\n                self.transport.close()\n                self._opened = False\n        else:\n            self.transport.close()\n\n    def stop(self, *, reason: str = "stop") -> list[str]:\n        """Send a repeated STOP sequence. STOP is always allowed."""\n\n        del reason\n        self.safety_policy.assert_stop_is_allowed()\n        written_lines: list[str] = []\n        for command in build_stop_sequence(repeat=self.stop_repeat):\n            line = serialize_json_line(command)\n            self.transport.write_line(line)\n            written_lines.append(line.rstrip("\\n"))\n            if self.stop_interval_sec > 0.0:\n                time.sleep(self.stop_interval_sec)\n        self._last_motion_monotonic = None\n        self._deadman_stop_sent = False\n        return written_lines\n\n    def send_velocity(\n        self,\n        *,\n        linear_x_mps: float,\n        angular_z_rad_s: float,\n    ) -> str:\n        """Validate, clamp and send one velocity command."""\n\n        linear, angular = self.safety_policy.validate_velocity_request(\n            linear_x_mps=linear_x_mps,\n            angular_z_rad_s=angular_z_rad_s,\n        )\n        command = build_ros_velocity_command(\n            linear_x_mps=linear,\n            angular_z_rad_s=angular,\n        )\n        line = serialize_json_line(command)\n        self.transport.write_line(line)\n\n        if is_zero_velocity(linear_x_mps=linear, angular_z_rad_s=angular):\n            self._last_motion_monotonic = None\n            self._deadman_stop_sent = False\n        else:\n            self._last_motion_monotonic = time.monotonic()\n            self._deadman_stop_sent = False\n        return line.rstrip("\\n")\n\n    def drive_forward(self, *, speed_mps: float | None = None) -> str:\n        speed = self.safety_policy.default_linear_speed_mps if speed_mps is None else speed_mps\n        return self.send_velocity(linear_x_mps=abs(float(speed)), angular_z_rad_s=0.0)\n\n    def drive_backward(self, *, speed_mps: float | None = None) -> str:\n        speed = self.safety_policy.default_linear_speed_mps if speed_mps is None else speed_mps\n        return self.send_velocity(linear_x_mps=-abs(float(speed)), angular_z_rad_s=0.0)\n\n    def rotate_left(self, *, speed_rad_s: float | None = None) -> str:\n        speed = self.safety_policy.default_angular_speed_rad_s if speed_rad_s is None else speed_rad_s\n        return self.send_velocity(linear_x_mps=0.0, angular_z_rad_s=abs(float(speed)))\n\n    def rotate_right(self, *, speed_rad_s: float | None = None) -> str:\n        speed = self.safety_policy.default_angular_speed_rad_s if speed_rad_s is None else speed_rad_s\n        return self.send_velocity(linear_x_mps=0.0, angular_z_rad_s=-abs(float(speed)))\n\n    def check_deadman(self, *, now_monotonic: float | None = None) -> bool:\n        """\n        Send STOP when a movement command is not refreshed in time.\n\n        Returns true when this call sent a watchdog STOP.\n        """\n\n        if self._last_motion_monotonic is None or self._deadman_stop_sent:\n            return False\n        now = time.monotonic() if now_monotonic is None else float(now_monotonic)\n        elapsed_ms = (now - self._last_motion_monotonic) * 1000.0\n        if elapsed_ms < float(self.safety_policy.deadman_timeout_ms):\n            return False\n        self.stop(reason="deadman_timeout")\n        self._deadman_stop_sent = True\n        return True\n\n    def read_available_lines(self, *, duration_sec: float = 0.0) -> list[str]:\n        return self.transport.read_available_lines(duration_sec=duration_sec)\n\n    def __enter__(self) -> "MobileBaseController":\n        self.open()\n        return self\n\n    def __exit__(self, exc_type: object, exc: object, tb: object) -> None:\n        self.close()\n\n\n__all__ = ["LineTransport", "MobileBaseController"]\n',
+    'modules/devices/mobile_base/safety.py': 'from __future__ import annotations\n\nimport math\nimport os\nfrom dataclasses import dataclass\n\n\nDEFAULT_MOVEMENT_CONFIRM_ENV = "CONFIRM_NEXA_MOBILE_BASE_MOVE"\nDEFAULT_MOVEMENT_CONFIRM_VALUE = "RUN"\n\n\nclass MobileBaseSafetyError(RuntimeError):\n    """Raised when a requested mobile base movement is not allowed safely."""\n\n\n@dataclass(frozen=True, slots=True)\nclass MobileBaseSafetyPolicy:\n    """\n    Central safety policy for mobile base movement commands.\n\n    STOP commands are always allowed. Any non-zero movement command is blocked\n    unless movement_enabled is true and the optional environment gate is open.\n    """\n\n    movement_enabled: bool = False\n    require_movement_confirm_env: bool = True\n    movement_confirm_env: str = DEFAULT_MOVEMENT_CONFIRM_ENV\n    movement_confirm_value: str = DEFAULT_MOVEMENT_CONFIRM_VALUE\n    default_linear_speed_mps: float = 0.04\n    default_angular_speed_rad_s: float = 0.18\n    max_linear_speed_mps: float = 0.08\n    max_angular_speed_rad_s: float = 0.25\n    max_command_duration_ms: int = 350\n    deadman_timeout_ms: int = 250\n\n    def assert_stop_is_allowed(self) -> None:\n        """STOP is always allowed and intentionally has no hardware gate."""\n\n    def assert_movement_is_allowed(self) -> None:\n        """Validate all gates required for non-zero movement."""\n\n        if not self.movement_enabled:\n            raise MobileBaseSafetyError("Mobile base movement is disabled by safety policy.")\n        if self.require_movement_confirm_env:\n            actual_value = os.environ.get(self.movement_confirm_env)\n            if actual_value != self.movement_confirm_value:\n                raise MobileBaseSafetyError(\n                    "Mobile base movement gate is closed. "\n                    f"Set {self.movement_confirm_env}={self.movement_confirm_value} only for a controlled test."\n                )\n\n    def clamp_linear_speed(self, value: float) -> float:\n        """Clamp linear speed to the configured symmetric safety range."""\n\n        return _clamp_float(\n            value,\n            lower=-abs(self.max_linear_speed_mps),\n            upper=abs(self.max_linear_speed_mps),\n            field_name="linear_x_mps",\n        )\n\n    def clamp_angular_speed(self, value: float) -> float:\n        """Clamp angular speed to the configured symmetric safety range."""\n\n        return _clamp_float(\n            value,\n            lower=-abs(self.max_angular_speed_rad_s),\n            upper=abs(self.max_angular_speed_rad_s),\n            field_name="angular_z_rad_s",\n        )\n\n    def clamp_duration_ms(self, value: int | float) -> int:\n        """Clamp a requested movement duration to the configured maximum."""\n\n        duration = int(value)\n        if duration < 0:\n            raise MobileBaseSafetyError("duration_ms must not be negative")\n        return min(duration, int(self.max_command_duration_ms))\n\n    def validate_velocity_request(\n        self,\n        *,\n        linear_x_mps: float,\n        angular_z_rad_s: float,\n    ) -> tuple[float, float]:\n        """\n        Validate and clamp a velocity request.\n\n        A zero velocity request is treated as STOP and is always allowed.\n        """\n\n        linear = self.clamp_linear_speed(linear_x_mps)\n        angular = self.clamp_angular_speed(angular_z_rad_s)\n        if is_zero_velocity(linear_x_mps=linear, angular_z_rad_s=angular):\n            self.assert_stop_is_allowed()\n            return 0.0, 0.0\n        self.assert_movement_is_allowed()\n        return linear, angular\n\n\ndef is_zero_velocity(*, linear_x_mps: float, angular_z_rad_s: float) -> bool:\n    """Return true when a velocity request is effectively STOP."""\n\n    return abs(float(linear_x_mps)) < 1e-9 and abs(float(angular_z_rad_s)) < 1e-9\n\n\ndef _clamp_float(value: float, *, lower: float, upper: float, field_name: str) -> float:\n    number = float(value)\n    if not math.isfinite(number):\n        raise MobileBaseSafetyError(f"{field_name} must be finite")\n    return max(float(lower), min(float(upper), number))\n\n\n__all__ = [\n    "DEFAULT_MOVEMENT_CONFIRM_ENV",\n    "DEFAULT_MOVEMENT_CONFIRM_VALUE",\n    "MobileBaseSafetyError",\n    "MobileBaseSafetyPolicy",\n    "is_zero_velocity",\n]\n',
