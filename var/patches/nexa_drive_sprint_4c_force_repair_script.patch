+    'modules/runtime/drive_mode/drive_mode_service.py': 'from __future__ import annotations\n\nfrom dataclasses import dataclass\nfrom typing import Any, Protocol\n\nfrom .keyboard_mapping import DriveModeAction, MOTION_ACTIONS, map_keyboard_event\n\n\nclass DriveController(Protocol):\n    """Controller subset required by manual drive mode."""\n\n    def drive_forward(self, *, speed_mps: float | None = None) -> str: ...\n    def drive_backward(self, *, speed_mps: float | None = None) -> str: ...\n    def rotate_left(self, *, speed_rad_s: float | None = None) -> str: ...\n    def rotate_right(self, *, speed_rad_s: float | None = None) -> str: ...\n    def send_velocity(self, *, linear_x_mps: float, angular_z_rad_s: float) -> str: ...\n    def stop(self, *, reason: str = "stop") -> list[str]: ...\n    def check_deadman(self, *, now_monotonic: float | None = None) -> bool: ...\n\n\n@dataclass(frozen=True, slots=True)\nclass DriveModeEventResult:\n    """Result returned after handling one drive-mode input event."""\n\n    ok: bool\n    action: DriveModeAction\n    event: str\n    command: str | None = None\n    stopped: bool = False\n    exit_requested: bool = False\n    deadman_stop: bool = False\n    error: str | None = None\n\n    def as_dict(self) -> dict[str, Any]:\n        return {\n            "ok": self.ok,\n            "action": self.action.value,\n            "event": self.event,\n            "command": self.command,\n            "stopped": self.stopped,\n            "exit_requested": self.exit_requested,\n            "deadman_stop": self.deadman_stop,\n            "error": self.error,\n        }\n\n\nclass DriveModeService:\n    """Manual drive-mode coordinator with key-up and combined-key support."""\n\n    def __init__(\n        self,\n        *,\n        controller: DriveController,\n        linear_speed_mps: float | None = None,\n        angular_speed_rad_s: float | None = None,\n    ) -> None:\n        self.controller = controller\n        self.linear_speed_mps = linear_speed_mps\n        self.angular_speed_rad_s = angular_speed_rad_s\n        self.active_action: DriveModeAction | None = None\n        self.exit_requested = False\n\n    def handle_keyboard_event(self, *, event: str, key: str) -> DriveModeEventResult:\n        """Handle one legacy keydown/keyup event from the local drive panel."""\n\n        normalized_event = str(event or "").strip().lower()\n        action = map_keyboard_event(key)\n        if action is DriveModeAction.UNKNOWN:\n            return DriveModeEventResult(ok=False, action=action, event=normalized_event, error="unknown_key")\n        if normalized_event not in {"down", "up"}:\n            return DriveModeEventResult(ok=False, action=action, event=normalized_event, error="unknown_event")\n        if normalized_event == "up":\n            return self._handle_key_up(action=action, event=normalized_event)\n        return self._handle_key_down(action=action, event=normalized_event)\n\n    def handle_pressed_keys(self, *, keys: list[str] | tuple[str, ...]) -> DriveModeEventResult:\n        """Handle the full currently pressed key set for combined movement."""\n\n        actions = {map_keyboard_event(key) for key in keys}\n        actions.discard(DriveModeAction.UNKNOWN)\n        if DriveModeAction.EXIT in actions:\n            return self._handle_key_down(action=DriveModeAction.EXIT, event="state")\n        if DriveModeAction.EMERGENCY_STOP in actions:\n            return self._handle_key_down(action=DriveModeAction.EMERGENCY_STOP, event="state")\n        linear = self._linear_from_actions(actions)\n        angular = self._angular_from_actions(actions)\n        action = self._combined_action(linear=linear, angular=angular)\n        if action is DriveModeAction.UNKNOWN:\n            if self.active_action is not None:\n                self.active_action = None\n                self.controller.stop(reason="drive_mode_key_state_release")\n                return DriveModeEventResult(ok=True, action=DriveModeAction.EMERGENCY_STOP, event="state", stopped=True)\n            return DriveModeEventResult(ok=True, action=action, event="state")\n        try:\n            command = self.controller.send_velocity(linear_x_mps=linear, angular_z_rad_s=angular)\n        except Exception as error:\n            self.active_action = None\n            self._best_effort_stop(reason="drive_mode_key_state_error")\n            return DriveModeEventResult(ok=False, action=action, event="state", stopped=True, error=str(error))\n        self.active_action = action\n        return DriveModeEventResult(ok=True, action=action, event="state", command=command)\n\n    def _handle_key_down(self, *, action: DriveModeAction, event: str) -> DriveModeEventResult:\n        if action is DriveModeAction.EMERGENCY_STOP:\n            self.active_action = None\n            self.controller.stop(reason="drive_mode_emergency_stop")\n            return DriveModeEventResult(ok=True, action=action, event=event, stopped=True)\n        if action is DriveModeAction.EXIT:\n            self.active_action = None\n            self.exit_requested = True\n            self.controller.stop(reason="drive_mode_exit")\n            return DriveModeEventResult(ok=True, action=action, event=event, stopped=True, exit_requested=True)\n        if action in MOTION_ACTIONS:\n            try:\n                command = self._send_motion(action)\n            except Exception as error:\n                self.active_action = None\n                self._best_effort_stop(reason="drive_mode_motion_error")\n                return DriveModeEventResult(ok=False, action=action, event=event, stopped=True, error=str(error))\n            self.active_action = action\n            return DriveModeEventResult(ok=True, action=action, event=event, command=command)\n        return DriveModeEventResult(ok=False, action=action, event=event, error="unsupported_action")\n\n    def _handle_key_up(self, *, action: DriveModeAction, event: str) -> DriveModeEventResult:\n        if action in MOTION_ACTIONS and self.active_action is action:\n            self.active_action = None\n            self.controller.stop(reason="drive_mode_key_release")\n            return DriveModeEventResult(ok=True, action=action, event=event, stopped=True)\n        if action is DriveModeAction.EMERGENCY_STOP:\n            return DriveModeEventResult(ok=True, action=action, event=event)\n        if action is DriveModeAction.EXIT:\n            return DriveModeEventResult(ok=True, action=action, event=event, exit_requested=self.exit_requested)\n        return DriveModeEventResult(ok=True, action=action, event=event)\n\n    def _send_motion(self, action: DriveModeAction) -> str:\n        if action is DriveModeAction.FORWARD:\n            return self.controller.drive_forward(speed_mps=self.linear_speed_mps)\n        if action is DriveModeAction.BACKWARD:\n            return self.controller.drive_backward(speed_mps=self.linear_speed_mps)\n        if action is DriveModeAction.ROTATE_LEFT:\n            return self.controller.rotate_left(speed_rad_s=self.angular_speed_rad_s)\n        if action is DriveModeAction.ROTATE_RIGHT:\n            return self.controller.rotate_right(speed_rad_s=self.angular_speed_rad_s)\n        if action in {DriveModeAction.FORWARD_LEFT, DriveModeAction.FORWARD_RIGHT, DriveModeAction.BACKWARD_LEFT, DriveModeAction.BACKWARD_RIGHT}:\n            linear, angular = self._velocity_for_combined_action(action)\n            return self.controller.send_velocity(linear_x_mps=linear, angular_z_rad_s=angular)\n        raise ValueError(f"Unsupported motion action: {action.value}")\n\n    def _linear_speed(self) -> float:\n        if self.linear_speed_mps is not None:\n            return float(self.linear_speed_mps)\n        policy = getattr(self.controller, "safety_policy", None)\n        return float(getattr(policy, "default_linear_speed_mps", 0.0) or 0.0)\n\n    def _angular_speed(self) -> float:\n        if self.angular_speed_rad_s is not None:\n            return float(self.angular_speed_rad_s)\n        policy = getattr(self.controller, "safety_policy", None)\n        return float(getattr(policy, "default_angular_speed_rad_s", 0.0) or 0.0)\n\n    def _linear_from_actions(self, actions: set[DriveModeAction]) -> float:\n        forward = DriveModeAction.FORWARD in actions\n        backward = DriveModeAction.BACKWARD in actions\n        if forward == backward:\n            return 0.0\n        speed = self._linear_speed()\n        return abs(speed) if forward else -abs(speed)\n\n    def _angular_from_actions(self, actions: set[DriveModeAction]) -> float:\n        left = DriveModeAction.ROTATE_LEFT in actions\n        right = DriveModeAction.ROTATE_RIGHT in actions\n        if left == right:\n            return 0.0\n        speed = self._angular_speed()\n        return abs(speed) if left else -abs(speed)\n\n    def _combined_action(self, *, linear: float, angular: float) -> DriveModeAction:\n        if linear > 0.0 and angular > 0.0:\n            return DriveModeAction.FORWARD_LEFT\n        if linear > 0.0 and angular < 0.0:\n            return DriveModeAction.FORWARD_RIGHT\n        if linear < 0.0 and angular > 0.0:\n            return DriveModeAction.BACKWARD_LEFT\n        if linear < 0.0 and angular < 0.0:\n            return DriveModeAction.BACKWARD_RIGHT\n        if linear > 0.0:\n            return DriveModeAction.FORWARD\n        if linear < 0.0:\n            return DriveModeAction.BACKWARD\n        if angular > 0.0:\n            return DriveModeAction.ROTATE_LEFT\n        if angular < 0.0:\n            return DriveModeAction.ROTATE_RIGHT\n        return DriveModeAction.UNKNOWN\n\n    def _velocity_for_combined_action(self, action: DriveModeAction) -> tuple[float, float]:\n        linear = self._linear_speed()\n        angular = self._angular_speed()\n        if action is DriveModeAction.FORWARD_LEFT:\n            return abs(linear), abs(angular)\n        if action is DriveModeAction.FORWAR