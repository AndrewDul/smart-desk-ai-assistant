+def _append_log(log_path: Path, message: str) -> None:
+    try:
+        log_path.parent.mkdir(parents=True, exist_ok=True)
+        with log_path.open("a", encoding="utf-8") as log_file:
+            log_file.write(message.rstrip("\n") + "\n")
+    except Exception:
+        pass
+
+
+def _request_existing_panel_exit(*, config: DriveModeLaunchConfig, log_path: Path) -> None:
+    """Ask a previously running panel to stop before starting with fresh gates."""
+
+    url = f"http://{config.status_host}:{int(config.http_port)}/api/key"
+    payload = json.dumps({"event": "down", "key": "Escape"}).encode("utf-8")
+    request = urllib.request.Request(
+        url,
+        data=payload,
+        headers={"Content-Type": "application/json"},
+        method="POST",
+    )
+    try:
+        with urllib.request.urlopen(request, timeout=0.5) as response:
+            _append_log(log_path, f"[VOICE-LAUNCH] Existing panel exit request status: {response.status}")
+    except urllib.error.URLError as error:
+        _append_log(log_path, f"[VOICE-LAUNCH] Existing panel exit request failed: {error}")
+    except Exception as error:
+        _append_log(log_path, f"[VOICE-LAUNCH] Existing panel exit request failed: {error}")
+
+
+def _wait_for_http_port_to_close(*, host: str, port: int, timeout_sec: float = 2.0) -> bool:
+    deadline = time.monotonic() + max(0.0, float(timeout_sec))
+    while time.monotonic() < deadline:
+        if not _is_http_port_alive(host=host, port=port, timeout_sec=0.1):
+            return True
+        time.sleep(0.1)
+    return not _is_http_port_alive(host=host, port=port, timeout_sec=0.1)
+
+
+def _force_kill_panel_port(*, config: DriveModeLaunchConfig, log_path: Path) -> None:
+    """Last-resort cleanup for stale local drive panel processes."""
+
+    port_spec = f"{int(config.http_port)}/tcp"
+    try:
+        with log_path.open("a", encoding="utf-8") as log_file:
+            log_file.write(f"[VOICE-LAUNCH] Force-killing stale panel port: {port_spec}\n")
+            subprocess.run(
+                ("fuser", "-k", port_spec),
+                cwd=str(config.project_root),
+                stdout=log_file,
+                stderr=subprocess.STDOUT,
+                check=False,
+            )
+    except FileNotFoundError:
+        _append_log(log_path, "[VOICE-LAUNCH] fuser is not available; cannot force-kill stale panel port.")
+    except Exception as error:
+        _append_log(log_path, f"[VOICE-LAUNCH] Force-kill failed: {error}")
+
+
 def _auto_open_panel(*, config: DriveModeLaunchConfig, log_path: Path) -> None:
