@@ -0,0 +1,85 @@
+from __future__ import annotations
+
+from typing import Any
+
+from modules.runtime.drive_mode import DriveModeVoiceLauncher
+
+from .models import ResolvedAction, SkillResult
+
+
+class ActionDriveModeActionsMixin:
+    """ActionFlow handlers for safe mobile-base manual drive mode."""
+
+    def _handle_drive_mode_start(
+        self,
+        *,
+        route: Any,
+        language: str,
+        payload: dict[str, Any],
+        resolved: ResolvedAction,
+    ) -> SkillResult:
+        del route, payload
+        result = DriveModeVoiceLauncher().launch()
+        lang = self.assistant._normalize_lang(language)
+        if result.ok:
+            spoken = self._drive_mode_started_spoken(language=lang, panel_url=result.panel_url)
+            if not result.movement_enabled:
+                spoken += " " + self._localized(
+                    lang,
+                    "Ruch bazy jest nadal zablokowany przez bramkę bezpieczeństwa.",
+                    "Mobile base movement is still locked by the safety gate.",
+                )
+            delivered = self._deliver_simple_action_response(
+                language=lang,
+                action="drive_mode_start",
+                spoken_text=spoken,
+                display_title=self._localized(lang, "TRYB STEROWANIA", "DRIVE MODE"),
+                display_lines=self._localized_lines(lang, ["W A S D", "spacja = stop", "Esc = wyjscie"], ["W A S D", "space = stop", "Esc = exit"]),
+                extra_metadata={
+                    "resolved_source": getattr(resolved, "source", ""),
+                    "drive_mode_status": result.status,
+                    "panel_url": result.panel_url,
+                    "pid": result.pid,
+                    "movement_enabled": result.movement_enabled,
+                    "log_path": result.log_path,
+                },
+            )
+            return SkillResult(
+                action="drive_mode_start",
+                handled=True,
+                response_delivered=bool(delivered),
+                status=result.status,
+                metadata={"source": "drive_mode_voice_launcher", "response_kind": "direct_response", "panel_url": result.panel_url, "pid": result.pid, "movement_enabled": result.movement_enabled, "log_path": result.log_path},
+            )
+        delivered = self._deliver_simple_action_response(
+            language=lang,
+            action="drive_mode_start",
+            spoken_text=self._localized(lang, "Nie uruchomiłam trybu sterowania bazą, ponieważ bramka bezpieczeństwa sprzętu jest zamknięta.", "I did not start mobile base drive mode because the hardware safety gate is closed."),
+            display_title=self._localized(lang, "DRIVE GATE", "DRIVE GATE"),
+            display_lines=self._localized_lines(lang, ["hardware gate", "zamkniety"], ["hardware gate", "closed"]),
+            extra_metadata={"resolved_source": getattr(resolved, "source", ""), "drive_mode_status": result.status, "message": result.message, "panel_url": result.panel_url, "log_path": result.log_path},
+        )
+        return SkillResult(
+            action="drive_mode_start",
+            handled=True,
+            response_delivered=bool(delivered),
+            status=result.status,
+            metadata={"source": "drive_mode_voice_launcher", "response_kind": "direct_response", "error": result.message, "log_path": result.log_path},
+        )
+
+    def _drive_mode_started_spoken(self, *, language: str, panel_url: str) -> str:
+        if self.assistant._normalize_lang(language) == "pl":
+            return (
+                "Tryb sterowania bazą jest uruchomiony. Otwórz panel sterowania i używaj W, A, S, D. "
+                "Przytrzymanie klawisza wykonuje ruch, puszczenie klawisza zatrzymuje ruch. "
+                "W plus A jedzie i skręca w lewo, W plus D jedzie i skręca w prawo. "
+                "Spacja zatrzymuje awaryjnie, a Escape wychodzi z trybu. "
+                f"Panel: {panel_url}"
+            )
+        return (
+            "Mobile base drive mode is running. Open the drive panel and use W, A, S, D. "
+            "Holding a key moves the base, releasing it stops that movement. "
+            "W plus A drives and turns left, W plus D drives and turns right. "
+            "Space is emergency stop, and Escape exits drive mode. "
+            f"Panel: {panel_url}"
+        )
