--- a/modules/runtime/drive_mode/voice_launcher.py	1970-01-01 00:00:00.000000000 +0000
+++ b/modules/runtime/drive_mode/voice_launcher.py	2026-05-08 17:53:59.034679885 +0000
@@ -0,0 +1,221 @@
+from __future__ import annotations
+
+import os
+import socket
+import subprocess
+import sys
+import time
+from dataclasses import dataclass
+from pathlib import Path
+from typing import Mapping
+
+from modules.devices.mobile_base import (
+    DEFAULT_MOVEMENT_CONFIRM_ENV,
+    DEFAULT_MOVEMENT_CONFIRM_VALUE,
+)
+
+
+CONFIRM_TEST_ENV_VAR = "CONFIRM_NEXA_MOBILE_BASE_TEST"
+CONFIRM_TEST_ENV_VALUE = "RUN"
+DRIVE_MODE_HOST_ENV = "NEXA_DRIVE_MODE_HOST"
+DRIVE_MODE_HTTP_PORT_ENV = "NEXA_DRIVE_MODE_HTTP_PORT"
+DRIVE_MODE_DRY_RUN_ENV = "NEXA_DRIVE_MODE_DRY_RUN"
+DRIVE_MODE_ENABLE_MOVEMENT_ENV = "NEXA_DRIVE_MODE_ENABLE_MOVEMENT"
+DRIVE_MODE_SERIAL_PORT_ENV = "NEXA_MOBILE_BASE_SERIAL_PORT"
+DRIVE_MODE_LINEAR_SPEED_ENV = "NEXA_DRIVE_MODE_LINEAR_SPEED_MPS"
+DRIVE_MODE_ANGULAR_SPEED_ENV = "NEXA_DRIVE_MODE_ANGULAR_SPEED_RAD_S"
+DRIVE_MODE_LOG_PATH_ENV = "NEXA_DRIVE_MODE_LOG_PATH"
+
+
+@dataclass(frozen=True, slots=True)
+class DriveModeLaunchConfig:
+    """Configuration used when Voice Runtime starts manual drive mode."""
+
+    project_root: Path
+    host: str = "127.0.0.1"
+    http_port: int = 8768
+    dry_run: bool = False
+    serial_port: str = ""
+    enable_movement: bool = False
+    movement_requested: bool = False
+    linear_speed_mps: float = 0.15
+    angular_speed_rad_s: float = 0.30
+    log_path: Path | None = None
+
+    @property
+    def panel_url(self) -> str:
+        host = "127.0.0.1" if self.host in {"", "0.0.0.0"} else self.host
+        return f"http://{host}:{int(self.http_port)}/"
+
+    @property
+    def status_host(self) -> str:
+        return "127.0.0.1" if self.host in {"", "0.0.0.0"} else self.host
+
+
+@dataclass(frozen=True, slots=True)
+class DriveModeLaunchResult:
+    """Result of a voice-triggered drive mode launch attempt."""
+
+    ok: bool
+    status: str
+    message: str
+    panel_url: str = ""
+    command: tuple[str, ...] = ()
+    pid: int | None = None
+    movement_enabled: bool = False
+    log_path: str = ""
+
+
+def _truthy(value: object) -> bool:
+    return str(value or "").strip().lower() in {"1", "true", "yes", "y", "on", "run"}
+
+
+def _safe_int(value: object, default: int) -> int:
+    try:
+        return int(str(value).strip())
+    except Exception:
+        return int(default)
+
+
+def _safe_float(value: object, default: float) -> float:
+    try:
+        return float(str(value).strip())
+    except Exception:
+        return float(default)
+
+
+def build_drive_mode_launch_config_from_env(
+    *,
+    env: Mapping[str, str] | None = None,
+    project_root: Path | None = None,
+) -> DriveModeLaunchConfig:
+    """Build a safe launch config from runtime environment variables."""
+
+    source = dict(os.environ if env is None else env)
+    root = project_root or Path(__file__).resolve().parents[3]
+    movement_requested = _truthy(source.get(DRIVE_MODE_ENABLE_MOVEMENT_ENV))
+    movement_gate_open = source.get(DEFAULT_MOVEMENT_CONFIRM_ENV) == DEFAULT_MOVEMENT_CONFIRM_VALUE
+    enable_movement = bool(movement_requested and movement_gate_open)
+    configured_log = str(source.get(DRIVE_MODE_LOG_PATH_ENV, "")).strip()
+    log_path = Path(configured_log) if configured_log else root / "var" / "log" / "mobile_base_drive_mode_voice.log"
+
+    return DriveModeLaunchConfig(
+        project_root=root,
+        host=str(source.get(DRIVE_MODE_HOST_ENV, "127.0.0.1") or "127.0.0.1"),
+        http_port=_safe_int(source.get(DRIVE_MODE_HTTP_PORT_ENV), 8768),
+        dry_run=_truthy(source.get(DRIVE_MODE_DRY_RUN_ENV)),
+        serial_port=str(source.get(DRIVE_MODE_SERIAL_PORT_ENV, "") or ""),
+        enable_movement=enable_movement,
+        movement_requested=movement_requested,
+        linear_speed_mps=_safe_float(source.get(DRIVE_MODE_LINEAR_SPEED_ENV), 0.15),
+        angular_speed_rad_s=_safe_float(source.get(DRIVE_MODE_ANGULAR_SPEED_ENV), 0.30),
+        log_path=log_path,
+    )
+
+
+def build_drive_mode_launch_command(config: DriveModeLaunchConfig) -> tuple[str, ...]:
+    """Return the subprocess command used to run the web drive panel."""
+
+    script_path = config.project_root / "scripts" / "mobile_base_drive_mode.py"
+    command: list[str] = [
+        sys.executable,
+        str(script_path),
+        "--host",
+        str(config.host),
+        "--http-port",
+        str(int(config.http_port)),
+        "--linear-speed-mps",
+        f"{float(config.linear_speed_mps):.3f}",
+        "--angular-speed-rad-s",
+        f"{float(config.angular_speed_rad_s):.3f}",
+    ]
+    if config.dry_run:
+        command.append("--dry-run")
+    if config.serial_port:
+        command.extend(["--port", str(config.serial_port)])
+    if config.enable_movement:
+        command.append("--enable-movement")
+    return tuple(command)
+
+
+def _is_http_port_alive(*, host: str, port: int, timeout_sec: float = 0.15) -> bool:
+    try:
+        with socket.create_connection((host, int(port)), timeout=float(timeout_sec)):
+            return True
+    except OSError:
+        return False
+
+
+class DriveModeVoiceLauncher:
+    """Starts the manual drive panel without blocking Voice Runtime."""
+
+    def __init__(self, *, config: DriveModeLaunchConfig | None = None) -> None:
+        self.config = config or build_drive_mode_launch_config_from_env()
+
+    def launch(self) -> DriveModeLaunchResult:
+        config = self.config
+        if _is_http_port_alive(host=config.status_host, port=config.http_port):
+            return DriveModeLaunchResult(
+                ok=True,
+                status="already_running",
+                message="Drive mode panel is already running.",
+                panel_url=config.panel_url,
+                movement_enabled=config.enable_movement,
+                log_path=str(config.log_path or ""),
+            )
+        if not config.dry_run and os.environ.get(CONFIRM_TEST_ENV_VAR) != CONFIRM_TEST_ENV_VALUE:
+            return DriveModeLaunchResult(
+                ok=False,
+                status="hardware_gate_closed",
+                message=(
+                    f"Hardware gate is closed. Set {CONFIRM_TEST_ENV_VAR}={CONFIRM_TEST_ENV_VALUE} "
+                    "before voice-starting drive mode against the real mobile base."
+                ),
+                panel_url=config.panel_url,
+                movement_enabled=False,
+                log_path=str(config.log_path or ""),
+            )
+        command = build_drive_mode_launch_command(config)
+        log_path = config.log_path or (config.project_root / "var" / "log" / "mobile_base_drive_mode_voice.log")
+        log_path.parent.mkdir(parents=True, exist_ok=True)
+        with log_path.open("a", encoding="utf-8") as log_file:
+            log_file.write("\n[VOICE-LAUNCH] Starting drive mode panel\n")
+            log_file.write("[VOICE-LAUNCH] Command: " + " ".join(command) + "\n")
+            process = subprocess.Popen(
+                command,
+                cwd=str(config.project_root),
+                stdout=log_file,
+                stderr=subprocess.STDOUT,
+                start_new_session=True,
+            )
+        time.sleep(0.25)
+        if process.poll() is not None:
+            return DriveModeLaunchResult(
+                ok=False,
+                status="process_exited",
+                message="Drive mode process exited immediately. Check the drive mode voice log.",
+                panel_url=config.panel_url,
+                command=command,
+                pid=process.pid,
+                movement_enabled=config.enable_movement,
+                log_path=str(log_path),
+            )
+        return DriveModeLaunchResult(
+            ok=True,
+            status="started",
+            message="Drive mode panel started.",
+            panel_url=config.panel_url,
+            command=command,
+            pid=process.pid,
+            movement_enabled=config.enable_movement,
+            log_path=str(log_path),
+        )
+
+
+__all__ = [
+    "DriveModeLaunchConfig",
+    "DriveModeLaunchResult",
+    "DriveModeVoiceLauncher",
+    "build_drive_mode_launch_command",
+    "build_drive_mode_launch_config_from_env",
+]
