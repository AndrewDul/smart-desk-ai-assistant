        self.action_labels = {
            "help": "help / pomoc",
            "status": "status / stan",
            "debug_status": "debug status / status debug",
            "memory_list": "memory / pamięć",
            "memory_clear": "clear memory / wyczyść pamięć",
            "memory_store": "remember / zapamiętaj",
